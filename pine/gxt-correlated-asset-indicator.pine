//@version=6
indicator(
     "GxT Correlated Asset Indicator",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500,
     dynamic_requests = false
 )

TZ = "America/New_York"
SESSION_HOUR = 18
WEEKLY_END_HOUR = 17
LEVEL_COLOR = color.black
SWING_MITIGATED_COLOR = color.new(color.gray, 35)
SESSION_CONTEXT_COLOR = color.new(color.gray, 30)
FVG_COLOR = color.new(color.teal, 85)
POI_COLOR = color.new(color.orange, 0)
POI_FVG_COLOR = color.new(color.orange, 70)
POI_FVG_BORDER = color.new(color.orange, 15)
POI_LINE_WIDTH = 2
DOL_COLOR = color.new(color.purple, 0)
DOL_FVG_COLOR = color.new(color.purple, 70)
DOL_FVG_BORDER = color.new(color.purple, 15)
DOL_LINE_WIDTH = 2
LABEL_SIZE = size.small
LABEL_GAP_TICKS = 2
ADR_LOOKBACK = 14
BAR_TIME_SEARCH_MAX = 4999

// f_bar_index_for_time scans time[] on barstate.islast (realtime). Without an explicit
// buffer, Pine auto-sizes too small on the last bar and throws CE overflow errors.
max_bars_back(time, BAR_TIME_SEARCH_MAX + 1)

// Map a timestamp to the chart bar that contains it (avoids bar_time rounding forward).
// Future targets (e.g. current session close at 17:00 ET) project forward from the active bar.
f_bar_index_for_time(int target_time) =>
    int result = bar_index
    if not na(target_time)
        if target_time > time_close
            int ms_per_bar = timeframe.in_seconds() * 1000
            result := bar_index + int(math.ceil((target_time - time) / ms_per_bar))
        else if target_time >= time
            result := bar_index
        else
            int max_i = math.min(bar_index, BAR_TIME_SEARCH_MAX)
            for i = 0 to max_i
                bool in_bar = time[i] <= target_time and (i == 0 or target_time < time[i - 1])
                if in_bar
                    result := bar_index - i
                    break
            if result == bar_index and time[max_i] > target_time
                result := bar_index - max_i
    result

showPdEquilibrium50 = input.bool(true, "Show PD 50% Equilibrium", group = "Session Context")
dailyBias = input.string("Directional", "Daily Bias", options = ["Directional", "Neutral"], group = "Session POI")
biasDirection = input.string("Bullish", "Bias Direction", options = ["Bullish", "Bearish"], group = "Active DOL")
reversalDayTp1 = input.bool(false, "Reversal Day TP1", group = "Active DOL")
failureSwingAdrPct = input.float(12.5, "Failure Swing ADR %", minval = 0, step = 0.1, group = "HTF Swings")

f_cme_daily_session_key_for(int t) =>
    et_hour = hour(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    if et_hour >= SESSION_HOUR
        timestamp(TZ, y, m, d, 0, 0)
    else
        timestamp(TZ, y, m, d, 0, 0) - 86400000

f_cme_daily_session_key() =>
    f_cme_daily_session_key_for(time)

f_daily_session_open_time() =>
    int session_day = f_cme_daily_session_key()
    y = year(session_day, TZ)
    m = month(session_day, TZ)
    d = dayofmonth(session_day, TZ)
    timestamp(TZ, y, m, d, SESSION_HOUR, 0)

f_current_daily_session_end() =>
    session_start_day = f_cme_daily_session_key()
    y = year(session_start_day, TZ)
    m = month(session_start_day, TZ)
    d = dayofmonth(session_start_day, TZ)
    timestamp(TZ, y, m, d + 1, WEEKLY_END_HOUR, 0)

f_in_cme_week() =>
    dow = dayofweek(time, TZ)
    et_hour = hour(time, TZ)
    et_minute = minute(time, TZ)
    sun_evening = dow == dayofweek.sunday and et_hour >= SESSION_HOUR
    mid_week = dow > dayofweek.sunday and dow < dayofweek.friday
    fri_close = dow == dayofweek.friday and (et_hour < WEEKLY_END_HOUR or (et_hour == WEEKLY_END_HOUR and et_minute == 0))
    sun_evening or mid_week or fri_close

f_in_cme_week_for(int t) =>
    dow = dayofweek(t, TZ)
    et_hour = hour(t, TZ)
    et_minute = minute(t, TZ)
    sun_evening = dow == dayofweek.sunday and et_hour >= SESSION_HOUR
    mid_week = dow > dayofweek.sunday and dow < dayofweek.friday
    fri_close = dow == dayofweek.friday and (et_hour < WEEKLY_END_HOUR or (et_hour == WEEKLY_END_HOUR and et_minute == 0))
    sun_evening or mid_week or fri_close

f_cme_week_session_key_for(int t) =>
    dow = dayofweek(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    offset = dow - 1
    sun_day = d - offset
    f_in_cme_week_for(t) ? timestamp(TZ, y, m, sun_day, SESSION_HOUR, 0) : na

f_cme_week_session_key() =>
    f_cme_week_session_key_for(time)

f_week_start_for(int t) =>
    dow = dayofweek(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    offset = dow - 1
    sun_day = d - offset
    timestamp(TZ, y, m, sun_day, SESSION_HOUR, 0)

f_week_end_for(int week_start) =>
    y = year(week_start, TZ)
    m = month(week_start, TZ)
    d = dayofmonth(week_start, TZ)
    timestamp(TZ, y, m, d + 5, WEEKLY_END_HOUR, 0)

f_resolve_week_session_key(int t) =>
    int direct = f_cme_week_session_key_for(t)
    if not na(direct)
        direct
    else
        int week_start = f_week_start_for(t)
        int week_end = f_week_end_for(week_start)
        t > week_end ? week_start : week_start - 7 * 86400000

f_previous_week_session_key(int week_key) =>
    week_key - 7 * 86400000

f_previous_daily_session_key(int session_key) =>
    session_key - 86400000

f_is_cme_holiday(int day_key) =>
    day_key == timestamp(TZ, 2025, 1, 20, 0, 0)

f_is_first_daily_session_of_cme_week(int session_key) =>
    int dow = dayofweek(session_key, TZ)
    bool is_monday = dow == dayofweek.monday
    bool is_tuesday_after_holiday = dow == dayofweek.tuesday and f_is_cme_holiday(session_key - 86400000)
    is_monday or is_tuesday_after_holiday

f_prior_friday_daily_session_key(int session_key) =>
    int dow = dayofweek(session_key, TZ)
    int week_sunday = dow == dayofweek.monday ? session_key - 86400000 : session_key - 2 * 86400000
    int friday = week_sunday - 2 * 86400000
    friday - 86400000

f_within_htf_fvg_lookback(int formedTime) =>
    int formedSession = f_cme_daily_session_key_for(formedTime)
    int asOfSession = f_cme_daily_session_key_for(time)
    if na(formedSession) or na(asOfSession)
        false
    else
        bool current = formedSession == asOfSession
        bool previous = formedSession == f_previous_daily_session_key(asOfSession)
        bool friday_bridge = f_is_first_daily_session_of_cme_week(asOfSession) and formedSession == f_prior_friday_daily_session_key(asOfSession)
        current or previous or friday_bridge

f_within_htf_swing_lookback(int formedTime) =>
    int formedWeek = f_resolve_week_session_key(formedTime)
    int asOfWeek = f_resolve_week_session_key(time)
    if na(formedWeek) or na(asOfWeek)
        false
    else
        formedWeek == asOfWeek or formedWeek == f_previous_week_session_key(asOfWeek)

f_within_htf_swing_comparison_lookback(int formedTime) =>
    int formedWeek = f_resolve_week_session_key(formedTime)
    int asOfWeek = f_resolve_week_session_key(time)
    if na(formedWeek) or na(asOfWeek)
        false
    else
        int weekKey = asOfWeek
        bool within = false
        for i = 0 to 3
            if formedWeek == weekKey
                within := true
                break
            weekKey := f_previous_week_session_key(weekKey)
        within

f_swing_visible(float price, int formedTime, float pwh, float pwl, float curWeekHigh, float curWeekLow) =>
    if not f_within_htf_swing_lookback(formedTime)
        false
    else
        float rangeLow = math.min(pwl, curWeekLow)
        float rangeHigh = math.max(pwh, curWeekHigh)
        price >= rangeLow and price <= rangeHigh

f_track_extreme(float cur_extreme, int cur_time, float candidate, int candidate_time) =>
    if na(cur_extreme) or candidate > cur_extreme
        [candidate, candidate_time]
    else
        [cur_extreme, cur_time]

f_track_extreme_low(float cur_extreme, int cur_time, float candidate, int candidate_time) =>
    if na(cur_extreme) or candidate < cur_extreme
        [candidate, candidate_time]
    else
        [cur_extreme, cur_time]

f_session_rails() =>
    var float cur_daily_high = na
    var float cur_daily_low = na
    var int cur_daily_high_time = na
    var int cur_daily_low_time = na
    var float cur_week_high = na
    var float cur_week_low = na
    var int cur_week_high_time = na
    var int cur_week_low_time = na
    var float out_pdh = na
    var float out_pdl = na
    var int out_pdh_time = na
    var int out_pdl_time = na
    var float out_pwh = na
    var float out_pwl = na
    var int out_pwh_time = na
    var int out_pwl_time = na
    var float out_daily_open = na
    var int out_daily_open_time = na
    var array<float> completed_daily_ranges = array.new_float(0)

    daily_key = f_cme_daily_session_key()
    week_key = f_cme_week_session_key()
    new_daily = ta.change(daily_key) != 0
    week_key_change = ta.change(week_key)
    new_week = not na(week_key) and week_key_change != 0

    if new_daily
        if not na(cur_daily_high)
            out_pdh := cur_daily_high
            out_pdl := cur_daily_low
            out_pdh_time := cur_daily_high_time
            out_pdl_time := cur_daily_low_time
            array.push(completed_daily_ranges, cur_daily_high - cur_daily_low)
            if array.size(completed_daily_ranges) > ADR_LOOKBACK
                array.shift(completed_daily_ranges)
        cur_daily_high := high
        cur_daily_low := low
        cur_daily_high_time := time
        cur_daily_low_time := time
        out_daily_open := open
        out_daily_open_time := time
    else
        [next_high, next_high_time] = f_track_extreme(cur_daily_high, cur_daily_high_time, high, time)
        [next_low, next_low_time] = f_track_extreme_low(cur_daily_low, cur_daily_low_time, low, time)
        cur_daily_high := next_high
        cur_daily_high_time := next_high_time
        cur_daily_low := next_low
        cur_daily_low_time := next_low_time

    if not na(week_key)
        if new_week
            if not na(cur_week_high)
                out_pwh := cur_week_high
                out_pwl := cur_week_low
                out_pwh_time := cur_week_high_time
                out_pwl_time := cur_week_low_time
            cur_week_high := high
            cur_week_low := low
            cur_week_high_time := time
            cur_week_low_time := time
        else
            [next_week_high, next_week_high_time] = f_track_extreme(cur_week_high, cur_week_high_time, high, time)
            [next_week_low, next_week_low_time] = f_track_extreme_low(cur_week_low, cur_week_low_time, low, time)
            cur_week_high := next_week_high
            cur_week_high_time := next_week_high_time
            cur_week_low := next_week_low
            cur_week_low_time := next_week_low_time

    float out_adr = na
    int range_count = array.size(completed_daily_ranges)
    if range_count > 0
        float range_sum = 0.0
        for i = 0 to range_count - 1
            range_sum += array.get(completed_daily_ranges, i)
        out_adr := range_sum / range_count

    float out_open_plus_adr = not na(out_daily_open) and not na(out_adr) ? out_daily_open + out_adr : na
    float out_open_minus_adr = not na(out_daily_open) and not na(out_adr) ? out_daily_open - out_adr : na
    float current_daily_range = not na(cur_daily_high) and not na(cur_daily_low) ? cur_daily_high - cur_daily_low : na
    float out_adr_consumption_pct = not na(current_daily_range) and not na(out_adr) and out_adr > 0 ? current_daily_range / out_adr * 100.0 : na

    [out_pdh, out_pdl, out_pwh, out_pwl, out_daily_open, out_pdh_time, out_pdl_time, out_pwh_time, out_pwl_time, out_daily_open_time, out_adr, out_open_plus_adr, out_open_minus_adr, out_adr_consumption_pct, cur_week_high, cur_week_low]

f_session_rails_with_end() =>
    [out_pdh, out_pdl, out_pwh, out_pwl, out_daily_open, out_pdh_time, out_pdl_time, out_pwh_time, out_pwl_time, out_daily_open_time, out_adr, out_open_plus_adr, out_open_minus_adr, out_adr_consumption_pct, cur_week_high, cur_week_low] = f_session_rails()
    int out_session_end = f_current_daily_session_end()

    var bool out_pdh_mitigated = false
    var int out_pdh_mitigated_time = na
    var bool out_pdl_mitigated = false
    var int out_pdl_mitigated_time = na
    var bool out_pwh_mitigated = false
    var int out_pwh_mitigated_time = na
    var bool out_pwl_mitigated = false
    var int out_pwl_mitigated_time = na

    daily_key = f_cme_daily_session_key()
    week_key = f_cme_week_session_key()
    new_daily = ta.change(daily_key) != 0
    new_week = not na(week_key) and ta.change(week_key) != 0

    if new_daily
        out_pdh_mitigated := false
        out_pdh_mitigated_time := na
        out_pdl_mitigated := false
        out_pdl_mitigated_time := na

    if new_week
        out_pwh_mitigated := false
        out_pwh_mitigated_time := na
        out_pwl_mitigated := false
        out_pwl_mitigated_time := na

    if not out_pdh_mitigated and not na(out_pdh) and not na(out_daily_open_time) and time >= out_daily_open_time and high >= out_pdh
        out_pdh_mitigated := true
        out_pdh_mitigated_time := time
    if not out_pdl_mitigated and not na(out_pdl) and not na(out_daily_open_time) and time >= out_daily_open_time and low <= out_pdl
        out_pdl_mitigated := true
        out_pdl_mitigated_time := time
    if not out_pwh_mitigated and not na(out_pwh) and not na(week_key) and time >= week_key and high >= out_pwh
        out_pwh_mitigated := true
        out_pwh_mitigated_time := time
    if not out_pwl_mitigated and not na(out_pwl) and not na(week_key) and time >= week_key and low <= out_pwl
        out_pwl_mitigated := true
        out_pwl_mitigated_time := time

    [out_pdh, out_pdl, out_pwh, out_pwl, out_daily_open, out_pdh_time, out_pdl_time, out_pwh_time, out_pwl_time, out_daily_open_time, out_adr, out_open_plus_adr, out_open_minus_adr, out_adr_consumption_pct, cur_week_high, cur_week_low, out_session_end, out_pdh_mitigated, out_pdh_mitigated_time, out_pdl_mitigated, out_pdl_mitigated_time, out_pwh_mitigated, out_pwh_mitigated_time, out_pwl_mitigated, out_pwl_mitigated_time]

[pdh, pdl, pwh, pwl, dailyOpen, pdhTime, pdlTime, pwhTime, pwlTime, dailyOpenTime, adr, openPlusAdr, openMinusAdr, adrConsumptionPct, currentWeekHigh, currentWeekLow, sessionEnd, pdhMitigated, pdhMitigatedTime, pdlMitigated, pdlMitigatedTime, pwhMitigated, pwhMitigatedTime, pwlMitigated, pwlMitigatedTime] = request.security(
     syminfo.tickerid,
     "1",
     f_session_rails_with_end(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[oneMinLows, oneMinHighs, oneMinTimes] = request.security_lower_tf(
     syminfo.tickerid,
     "1",
     [low, high, time]
 )

dailySessionKey = f_cme_daily_session_key()
var int prevDailySessionKey = na
sessionRolled = not na(dailySessionKey) and not na(prevDailySessionKey) and dailySessionKey != prevDailySessionKey
prevDailySessionKey := dailySessionKey

f_label_y(float price, string placement) =>
    gap = syminfo.mintick * LABEL_GAP_TICKS
    placement == "above" ? price + gap : placement == "below" ? price - gap : price

f_label_style(string placement) =>
    placement == "above" ? label.style_label_up : placement == "below" ? label.style_label_down : label.style_label_left

type HtfFvgZone
    float zoneLow
    float zoneHigh
    int formedTime
    string txt
    bool bullish
    bool mitigated
    int mitigatedTime
    int formedBi

type HtfSwingLevel
    float price
    int formedTime
    int confirmedTime
    string txt
    bool mitigated
    int mitigatedTime
    bool isFailureSwing
    int formedBi
    int mitigatedBi

type SessionPoiTarget
    string kind
    int formedTime
    string txt

f_fvg_overlaps_equilibrium(float zoneLow, float zoneHigh, float eqLow, float eqHigh) =>
    zoneLow <= eqHigh and zoneHigh >= eqLow

f_fvg_overlaps_biased_half(float zoneLow, float zoneHigh, float pdMidpoint, bool bullish) =>
    bullish ? zoneHigh >= pdMidpoint : zoneLow <= pdMidpoint

f_swing_in_biased_half(float price, float pdMidpoint, bool bullish) =>
    bullish ? price >= pdMidpoint : price <= pdMidpoint

f_timeframe_rank(string txt) =>
    str.contains(txt, "4H") ? 2 : 1

f_same_level_price(float left, float right) =>
    math.abs(left - right) <= syminfo.mintick / 2

f_swing_label_suppressed_by_higher_tf(array<HtfSwingLevel> swings, HtfSwingLevel swing) =>
    bool suppressed = false
    float swingRank = f_timeframe_rank(swing.txt)
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel other = array.get(swings, i)
            if not other.mitigated and f_timeframe_rank(other.txt) > swingRank and f_same_level_price(other.price, swing.price)
                suppressed := true
                break
    suppressed

f_daily_rail_label_suppressed(string kind, float price, float pwh, float pwl, bool pwhMitigated, bool pwlMitigated) =>
    bool suppressed = false
    if kind == "pdh" and not pwhMitigated and not na(pwh) and f_same_level_price(price, pwh)
        suppressed := true
    if kind == "pdl" and not pwlMitigated and not na(pwl) and f_same_level_price(price, pwl)
        suppressed := true
    suppressed

f_swing_label_suppressed_by_liquidity_rail(
     HtfSwingLevel swing,
     float pdh,
     float pdl,
     bool pdhMitigated,
     bool pdlMitigated,
     float pwh,
     float pwl,
     bool pwhMitigated,
     bool pwlMitigated
 ) =>
    bool isHigh = str.contains(swing.txt, "High")
    bool isLow = str.contains(swing.txt, "Low")
    bool suppressed = false
    if isHigh
        if not pdhMitigated and not na(pdh) and f_same_level_price(swing.price, pdh)
            suppressed := true
        if not pwhMitigated and not na(pwh) and f_same_level_price(swing.price, pwh)
            suppressed := true
    if isLow
        if not pdlMitigated and not na(pdl) and f_same_level_price(swing.price, pdl)
            suppressed := true
        if not pwlMitigated and not na(pwl) and f_same_level_price(swing.price, pwl)
            suppressed := true
    suppressed

f_is_session_poi(SessionPoiTarget poi, string kind, int formedTime, string txt) =>
    bool matches = not na(poi) and poi.kind == kind and poi.txt == txt
    kind == "pdh" or kind == "pdl" or kind == "pwh" or kind == "pwl" ? matches : matches and poi.formedTime == formedTime

f_select_directional_fvg_poi(
     array<HtfFvgZone> zones,
     float pdMidpoint,
     bool bullish,
     int sessionOpenTime,
     float currentPrice
 ) =>
    SessionPoiTarget best = na
    float bestRank = na
    float bestDistance = na
    int count = array.size(zones)
    if count > 0
        for i = 0 to count - 1
            HtfFvgZone zone = array.get(zones, i)
            bool eligible = not zone.mitigated and zone.formedTime <= sessionOpenTime and f_fvg_overlaps_biased_half(zone.zoneLow, zone.zoneHigh, pdMidpoint, bullish)
            if eligible
                float mid = (zone.zoneLow + zone.zoneHigh) / 2.0
                float dist = math.abs(currentPrice - mid)
                float rank = f_timeframe_rank(zone.txt)
                bool take = na(best) or rank > bestRank or (rank == bestRank and dist < bestDistance)
                if take
                    best := SessionPoiTarget.new("fvg", zone.formedTime, zone.txt)
                    bestRank := rank
                    bestDistance := dist
    best

f_select_defer_swing_poi(
     array<HtfSwingLevel> swings,
     int sessionOpenTime,
     float currentPrice,
     int asOfTime,
     float pwh,
     float pwl,
     float curWeekHigh,
     float curWeekLow,
     float pdMidpoint,
     bool bullish
 ) =>
    SessionPoiTarget best = na
    float bestRank = na
    float bestDistance = na
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel swing = array.get(swings, i)
            bool eligible = not swing.mitigated and not swing.isFailureSwing and swing.confirmedTime >= sessionOpenTime and swing.confirmedTime <= asOfTime and f_swing_visible(swing.price, swing.formedTime, pwh, pwl, curWeekHigh, curWeekLow) and f_swing_in_biased_half(swing.price, pdMidpoint, bullish)
            if eligible
                float dist = math.abs(currentPrice - swing.price)
                float rank = f_timeframe_rank(swing.txt)
                bool take = na(best) or rank > bestRank or (rank == bestRank and dist < bestDistance)
                if take
                    best := SessionPoiTarget.new("swing", swing.formedTime, swing.txt)
                    bestRank := rank
                    bestDistance := dist
    best

f_format_level_label(string txt, bool is_poi, bool is_continuation, bool is_tp1, bool is_tp2) =>
    string label_txt = txt
    if is_continuation
        label_txt += " · Continuation"
    else if is_poi
        label_txt += " · POI"
    if is_tp1
        label_txt += " · TP1"
    if is_tp2
        label_txt += " · TP2"
    label_txt

f_is_continuation_poi(SessionPoiTarget poi, string kind, int formedTime, string txt) =>
    bool matches = not na(poi) and poi.kind == kind and poi.txt == txt
    kind == "fvg" ? matches and poi.formedTime == formedTime : matches

f_find_opposing_1h_swing_before_flip(array<HtfSwingLevel> swings, int flippedAt, bool bullish) =>
    string wantTxt = bullish ? "1H Swing Low" : "1H Swing High"
    HtfSwingLevel best = na
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel swing = array.get(swings, i)
            bool eligible = swing.txt == wantTxt and not swing.mitigated and not swing.isFailureSwing and swing.confirmedTime <= flippedAt
            if eligible
                bool take = na(best) or swing.formedTime > best.formedTime
                if take
                    best := swing
    best

f_expansion_leg_midpoint(float origin, float terminus) =>
    (origin + terminus) / 2.0

f_fvg_within_upper_half(HtfFvgZone zone, float origin, float terminus, bool bullish) =>
    float midpoint = f_expansion_leg_midpoint(origin, terminus)
    bullish ? zone.zoneLow >= midpoint and zone.zoneHigh <= terminus : zone.zoneHigh <= midpoint and zone.zoneLow >= terminus

f_same_fvg_zone(HtfFvgZone left, HtfFvgZone right) =>
    left.formedTime == right.formedTime and left.txt == right.txt and left.zoneLow == right.zoneLow and left.zoneHigh == right.zoneHigh

f_pick_best_fvg_zone(array<HtfFvgZone> zones, float currentPrice) =>
    HtfFvgZone best = na
    float bestRank = na
    float bestDistance = na
    int count = array.size(zones)
    if count > 0
        for i = 0 to count - 1
            HtfFvgZone candidate = array.get(zones, i)
            float rank = f_timeframe_rank(candidate.txt)
            float mid = (candidate.zoneLow + candidate.zoneHigh) / 2.0
            float dist = math.abs(currentPrice - mid)
            bool take = na(best) or rank > bestRank or (rank == bestRank and dist < bestDistance)
            if take
                best := candidate
                bestRank := rank
                bestDistance := dist
    best

f_closes_past_expansion_leg_midpoint(float barClose, float origin, float terminus, bool bullish) =>
    float midpoint = f_expansion_leg_midpoint(origin, terminus)
    bullish ? barClose < midpoint : barClose > midpoint

f_select_continuation_fvg_poi(
     array<HtfFvgZone> zones,
     float expansionOrigin,
     float expansionTerminus,
     int sessionOpenTime,
     int asOfTime,
     float currentPrice,
     bool bullish,
     SessionPoiTarget excluded
 ) =>
    SessionPoiTarget best = na
    if not na(expansionOrigin) and not na(expansionTerminus)
        array<HtfFvgZone> candidates = array.new<HtfFvgZone>()
        int zone_count = array.size(zones)
        if zone_count > 0
            for i = 0 to zone_count - 1
                HtfFvgZone zone = array.get(zones, i)
                bool directionMatch = zone.bullish == bullish
                bool intraday = zone.formedTime >= sessionOpenTime and zone.formedTime <= asOfTime
                bool inUpperHalf = f_fvg_within_upper_half(zone, expansionOrigin, expansionTerminus, bullish)
                bool notExcluded = na(excluded) or excluded.formedTime != zone.formedTime or excluded.txt != zone.txt
                if not zone.mitigated and directionMatch and intraday and inUpperHalf and notExcluded
                    array.push(candidates, zone)
        HtfFvgZone selected = f_pick_best_fvg_zone(candidates, currentPrice)
        if not na(selected)
            best := SessionPoiTarget.new("fvg", selected.formedTime, selected.txt)
    best

f_is_active_dol(SessionPoiTarget target, string kind, int formedTime, string txt) =>
    bool matches = not na(target) and target.kind == kind and target.txt == txt
    kind == "daily-open" or kind == "pdh" or kind == "pdl" or kind == "pwh" or kind == "pwl" ? matches : matches and target.formedTime == formedTime

f_dol_in_bias_direction(bool bullish, float currentPrice, float levelPrice) =>
    bullish ? levelPrice > currentPrice : levelPrice < currentPrice

f_close_through_pd_midpoint_against_bias(bool bearishBias, float htfClose, float pdMidpoint) =>
    bearishBias ? htfClose > pdMidpoint : htfClose < pdMidpoint

f_dol_within_adr(bool bullish, float levelPrice, float openPlusAdr, float openMinusAdr) =>
    bullish ? levelPrice <= openPlusAdr : levelPrice >= openMinusAdr

f_dol_distance(float currentPrice, float levelPrice) =>
    math.abs(currentPrice - levelPrice)

f_dol_tier(string kind) =>
    kind == "pwh" or kind == "pwl" ? 3 : kind == "pdh" or kind == "pdl" ? 2 : 1

f_update_nearest_dol(
     SessionPoiTarget best,
     float bestDistance,
     SessionPoiTarget candidate,
     float candidatePrice,
     float currentPrice
 ) =>
    float dist = f_dol_distance(currentPrice, candidatePrice)
    bool take = na(best) or dist < bestDistance
    [take ? candidate : best, take ? dist : bestDistance]

f_update_furthest_dol(
     SessionPoiTarget best,
     float bestDistance,
     int bestTier,
     SessionPoiTarget candidate,
     float candidatePrice,
     float currentPrice
 ) =>
    float dist = f_dol_distance(currentPrice, candidatePrice)
    int tier = f_dol_tier(candidate.kind)
    bool take = na(best) or dist > bestDistance or (dist == bestDistance and tier > bestTier)
    [take ? candidate : best, take ? dist : bestDistance, take ? tier : bestTier]

f_resolve_active_dol(
     bool bullish,
     float currentPrice,
     float dailyOpen,
     float adrConsumptionPct,
     bool reversalDayTp1Enabled,
     float openPlusAdr,
     float openMinusAdr,
     float pdh,
     float pdl,
     float pwh,
     float pwl,
     bool pdhMitigated,
     bool pdlMitigated,
     bool pwhMitigated,
     bool pwlMitigated,
     float curWeekHigh,
     float curWeekLow,
     array<HtfSwingLevel> swings
 ) =>
    SessionPoiTarget nearest = na
    float nearestDistance = na
    SessionPoiTarget furthest = na
    float furthestDistance = na
    int furthestTier = na

    if not pdhMitigated and not na(pdh) and f_dol_in_bias_direction(bullish, currentPrice, pdh)
        SessionPoiTarget candidate = SessionPoiTarget.new("pdh", na, "PDH")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pdh, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pdh, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pdh, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pdlMitigated and not na(pdl) and f_dol_in_bias_direction(bullish, currentPrice, pdl)
        SessionPoiTarget candidate = SessionPoiTarget.new("pdl", na, "PDL")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pdl, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pdl, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pdl, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pwhMitigated and not na(pwh) and f_dol_in_bias_direction(bullish, currentPrice, pwh)
        SessionPoiTarget candidate = SessionPoiTarget.new("pwh", na, "PWH")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pwh, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pwh, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pwh, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pwlMitigated and not na(pwl) and f_dol_in_bias_direction(bullish, currentPrice, pwl)
        SessionPoiTarget candidate = SessionPoiTarget.new("pwl", na, "PWL")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pwl, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pwl, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pwl, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    int swing_count = array.size(swings)
    if swing_count > 0
        for i = 0 to swing_count - 1
            HtfSwingLevel swing = array.get(swings, i)
            bool bullishSwing = str.contains(swing.txt, "High")
            bool bearishSwing = str.contains(swing.txt, "Low")
            bool directionMatch = bullish ? bullishSwing : bearishSwing
            if not swing.mitigated and not swing.isFailureSwing and directionMatch and f_dol_in_bias_direction(bullish, currentPrice, swing.price) and f_swing_visible(swing.price, swing.formedTime, pwh, pwl, curWeekHigh, curWeekLow)
                SessionPoiTarget candidate = SessionPoiTarget.new("swing", swing.formedTime, swing.txt)
                [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, swing.price, currentPrice)
                nearest := nextNearest
                nearestDistance := nextNearestDistance
                if f_dol_within_adr(bullish, swing.price, openPlusAdr, openMinusAdr)
                    [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, swing.price, currentPrice)
                    furthest := nextFurthest
                    furthestDistance := nextFurthestDistance
                    furthestTier := nextFurthestTier

    bool useDailyOpenTp1 = reversalDayTp1Enabled and adrConsumptionPct >= 80 and not na(dailyOpen) and f_dol_in_bias_direction(bullish, currentPrice, dailyOpen)
    if useDailyOpenTp1
        nearest := SessionPoiTarget.new("daily-open", na, "Daily Open")

    [nearest, furthest]

f_poi_target_mitigated(SessionPoiTarget poi, array<HtfFvgZone> zones, array<HtfSwingLevel> swings) =>
    bool mitigated = false
    if not na(poi)
        if poi.kind == "fvg"
            bool found = false
            int zone_count = array.size(zones)
            if zone_count > 0
                for i = 0 to zone_count - 1
                    HtfFvgZone zone = array.get(zones, i)
                    if zone.formedTime == poi.formedTime and zone.txt == poi.txt
                        found := true
            mitigated := not found
        else if poi.kind == "swing"
            int swing_count = array.size(swings)
            if swing_count > 0
                for i = 0 to swing_count - 1
                    HtfSwingLevel swing = array.get(swings, i)
                    if swing.formedTime == poi.formedTime and swing.txt == poi.txt
                        mitigated := swing.mitigated
    mitigated

f_range_fully_in(float innerLow, float innerHigh, float outerLow, float outerHigh) =>
    innerLow >= outerLow and innerHigh <= outerHigh

f_middle_fully_overlapped_by_outer(int firstIdx, int middleIdx, int thirdIdx) =>
    float innerLow = low[middleIdx]
    float innerHigh = high[middleIdx]
    float aLow = low[firstIdx]
    float aHigh = high[firstIdx]
    float bLow = low[thirdIdx]
    float bHigh = high[thirdIdx]
    bool inFirst = f_range_fully_in(innerLow, innerHigh, aLow, aHigh)
    bool inThird = f_range_fully_in(innerLow, innerHigh, bLow, bHigh)
    bool spansFirstThenThird = innerLow >= aLow and aHigh >= innerLow and innerHigh <= bHigh and bLow <= aHigh
    bool spansThirdThenFirst = innerLow >= bLow and bHigh >= innerLow and innerHigh <= aHigh and aLow <= bHigh
    inFirst or inThird or spansFirstThenThird or spansThirdThenFirst

f_detect_fvg() =>
    bool bullish = low[0] > high[2]
    bool bearish = high[0] < low[2]
    bool middleOverlapped = f_middle_fully_overlapped_by_outer(2, 1, 0)
    float zoneLow = bullish ? high[2] : bearish ? high[0] : na
    float zoneHigh = bullish ? low[0] : bearish ? low[2] : na
    bool formed = (bullish or bearish) and not middleOverlapped
    [formed, zoneLow, zoneHigh, time, bullish]

f_detect_fvg_with_ohlc() =>
    [formed, zoneLow, zoneHigh, formedTime, bullish] = f_detect_fvg()
    [formed, zoneLow, zoneHigh, formedTime, bullish, low, high, time, close]

f_fvg_closed_through_extreme(bool bullish, float zoneLow, float zoneHigh, float checkClose) =>
    bullish ? checkClose < zoneLow : checkClose > zoneHigh

f_fvg_exists(array<HtfFvgZone> zones, int formedTime, string txt) =>
    bool found = false
    int count = array.size(zones)
    if count > 0
        for i = 0 to count - 1
            HtfFvgZone zone = array.get(zones, i)
            if zone.formedTime == formedTime and zone.txt == txt
                found := true
    found

f_try_add_fvg(
     array<HtfFvgZone> zones,
     bool formed,
     float zoneLow,
     float zoneHigh,
     int formedTime,
     string txt,
     bool bullish
 ) =>
    if formed and not f_fvg_exists(zones, formedTime, txt)
        array.push(zones, HtfFvgZone.new(zoneLow, zoneHigh, formedTime, txt, bullish, false, na, f_bar_index_for_time(formedTime)))
    zones

f_remove_mitigated_fvgs(array<HtfFvgZone> zones, float checkClose, int checkTime) =>
    int i = array.size(zones) - 1
    while i >= 0
        HtfFvgZone zone = array.get(zones, i)
        if checkTime > zone.formedTime and f_fvg_closed_through_extreme(zone.bullish, zone.zoneLow, zone.zoneHigh, checkClose)
            array.remove(zones, i)
        i -= 1
    zones

f_prune_expired_fvgs(array<HtfFvgZone> zones) =>
    int i = array.size(zones) - 1
    while i >= 0
        HtfFvgZone zone = array.get(zones, i)
        if not f_within_htf_fvg_lookback(zone.formedTime)
            array.remove(zones, i)
        i -= 1
    zones

f_advance_fvg_lifecycle(
     array<HtfFvgZone> zones,
     bool formed,
     float zoneLow,
     float zoneHigh,
     int formedTime,
     string txt,
     bool formedBullish,
     float checkClose,
     int checkTime,
     bool bar_confirmed
 ) =>
    array<HtfFvgZone> result = zones
    bool dirty = false
    if bar_confirmed
        int sizeBeforeAdd = array.size(result)
        result := f_try_add_fvg(result, formed, zoneLow, zoneHigh, formedTime, txt, formedBullish)
        dirty := array.size(result) != sizeBeforeAdd
    int sizeBeforeMitigate = array.size(result)
    result := f_remove_mitigated_fvgs(result, checkClose, checkTime)
    dirty := dirty or array.size(result) != sizeBeforeMitigate
    int sizeBeforePrune = array.size(result)
    result := f_prune_expired_fvgs(result)
    dirty := dirty or array.size(result) != sizeBeforePrune
    [result, dirty]

f_concat_fvg_arrays(array<HtfFvgZone> left, array<HtfFvgZone> right) =>
    array<HtfFvgZone> combined = array.copy(left)
    int right_count = array.size(right)
    if right_count > 0
        for i = 0 to right_count - 1
            array.push(combined, array.get(right, i))
    combined

var int sessionEndBi = na
if barstate.islast
    sessionEndBi := f_bar_index_for_time(sessionEnd)

var int dailyOpenOriginBi = na
var int cachedDailyOpenTime = na
if dailyOpenTime != cachedDailyOpenTime
    cachedDailyOpenTime := dailyOpenTime
    dailyOpenOriginBi := not na(dailyOpenTime) ? f_bar_index_for_time(dailyOpenTime) : na

var int pdhOriginBi = na
var int pdhMitigatedBi = na
var int cachedPdhTime = na
if pdhTime != cachedPdhTime
    cachedPdhTime := pdhTime
    pdhOriginBi := not na(pdhTime) ? f_bar_index_for_time(pdhTime) : na
    pdhMitigatedBi := na
if pdhMitigated
    if na(pdhMitigatedBi)
        pdhMitigatedBi := f_bar_index_for_time(pdhMitigatedTime)
else
    pdhMitigatedBi := na

var int pdlOriginBi = na
var int pdlMitigatedBi = na
var int cachedPdlTime = na
if pdlTime != cachedPdlTime
    cachedPdlTime := pdlTime
    pdlOriginBi := not na(pdlTime) ? f_bar_index_for_time(pdlTime) : na
    pdlMitigatedBi := na
if pdlMitigated
    if na(pdlMitigatedBi)
        pdlMitigatedBi := f_bar_index_for_time(pdlMitigatedTime)
else
    pdlMitigatedBi := na

var int pwhOriginBi = na
var int pwhMitigatedBi = na
var int cachedPwhTime = na
if pwhTime != cachedPwhTime
    cachedPwhTime := pwhTime
    pwhOriginBi := not na(pwhTime) ? f_bar_index_for_time(pwhTime) : na
    pwhMitigatedBi := na
if pwhMitigated
    if na(pwhMitigatedBi)
        pwhMitigatedBi := f_bar_index_for_time(pwhMitigatedTime)
else
    pwhMitigatedBi := na

var int pwlOriginBi = na
var int pwlMitigatedBi = na
var int cachedPwlTime = na
if pwlTime != cachedPwlTime
    cachedPwlTime := pwlTime
    pwlOriginBi := not na(pwlTime) ? f_bar_index_for_time(pwlTime) : na
    pwlMitigatedBi := na
if pwlMitigated
    if na(pwlMitigatedBi)
        pwlMitigatedBi := f_bar_index_for_time(pwlMitigatedTime)
else
    pwlMitigatedBi := na

f_draw_fvg_zones(
     array<box> existing_boxes,
     array<label> existing_labels,
     array<HtfFvgZone> zones,
     int session_end_bi,
     SessionPoiTarget session_poi,
     SessionPoiTarget continuation_poi,
     bool in_continuation_regime
 ) =>
    array<box> next_boxes = array.new<box>()
    array<label> next_labels = array.new<label>()
    if barstate.islast
        int box_count = array.size(existing_boxes)
        if box_count > 0
            for i = 0 to box_count - 1
                box.delete(array.get(existing_boxes, i))
        int label_count = array.size(existing_labels)
        if label_count > 0
            for i = 0 to label_count - 1
                label.delete(array.get(existing_labels, i))
        int zone_count = array.size(zones)
        if zone_count > 0
            for i = 0 to zone_count - 1
                HtfFvgZone zone = array.get(zones, i)
                int origin_bi = zone.formedBi
                int end_bi = math.max(origin_bi, session_end_bi)
                bool is_session_poi = not in_continuation_regime and f_is_session_poi(session_poi, "fvg", zone.formedTime, zone.txt)
                bool is_continuation = in_continuation_regime and f_is_continuation_poi(continuation_poi, "fvg", zone.formedTime, zone.txt)
                bool is_poi = is_session_poi or is_continuation
                color box_bg = is_poi ? POI_FVG_COLOR : FVG_COLOR
                color box_border = is_poi ? POI_FVG_BORDER : color.new(color.teal, 40)
                box next_box = box.new(
                     origin_bi,
                     zone.zoneHigh,
                     end_bi,
                     zone.zoneLow,
                     xloc = xloc.bar_index,
                     bgcolor = box_bg,
                     border_color = box_border,
                     border_width = is_poi ? POI_LINE_WIDTH : 1
                 )
                array.push(next_boxes, next_box)
                string label_txt = f_format_level_label(zone.txt, is_session_poi, is_continuation, false, false)
                color label_color = is_poi ? POI_COLOR : color.teal
                label next_label = label.new(
                     end_bi,
                     zone.zoneHigh,
                     label_txt,
                     xloc = xloc.bar_index,
                     style = label.style_label_down,
                     color = color(na),
                     textcolor = label_color,
                     size = LABEL_SIZE
                 )
                array.push(next_labels, next_label)
    [next_boxes, next_labels]

f_draw_level(
     line existing_line,
     label existing_label,
     float price,
     int origin_bi,
     int session_end_bi,
     string txt,
     bool dashed,
     string label_placement,
     color line_color,
     bool mitigated = false,
     int mitigated_bi = na,
     bool is_poi = false,
     bool is_tp1 = false,
     bool is_tp2 = false,
     bool session_context = false,
     bool suppress_label = false
 ) =>
    line next_line = na
    label next_label = na
    if barstate.islast
        if not na(existing_line)
            line.delete(existing_line)
        if not na(existing_label)
            label.delete(existing_label)
        if not na(price) and not na(origin_bi) and not na(session_end_bi)
            end_bi = mitigated ? math.max(origin_bi, mitigated_bi) : math.max(origin_bi, session_end_bi)
            color draw_color = is_poi ? POI_COLOR : (not session_context and (is_tp1 or is_tp2)) ? DOL_COLOR : mitigated ? SWING_MITIGATED_COLOR : line_color
            int line_width = is_poi ? POI_LINE_WIDTH : (not session_context and (is_tp1 or is_tp2)) ? DOL_LINE_WIDTH : 1
            next_line := line.new(
                 origin_bi,
                 price,
                 end_bi,
                 price,
                 xloc = xloc.bar_index,
                 extend = extend.none,
                 color = draw_color,
                 width = line_width,
                 style = dashed ? line.style_dashed : line.style_solid
             )
            if txt != "" and not suppress_label
                string label_txt = f_format_level_label(txt, is_poi, false, is_tp1, is_tp2)
                next_label := label.new(
                     end_bi,
                     f_label_y(price, label_placement),
                     label_txt,
                     xloc = xloc.bar_index,
                     style = f_label_style(label_placement),
                     color = color(na),
                     textcolor = draw_color,
                     size = LABEL_SIZE
                 )
    [next_line, next_label]

var line pdh_line = na
var line pdl_line = na
var line pwh_line = na
var line pwl_line = na
var line daily_open_line = na
var line open_plus_adr_line = na
var line open_minus_adr_line = na
var line pd_equilibrium_line = na
var label pdh_label = na
var label pdl_label = na
var label pwh_label = na
var label pwl_label = na
var label daily_open_label = na
var label adr_consumption_label = na
var label pd_equilibrium_label = na

var SessionPoiTarget sessionPoi = na
var SessionPoiTarget continuationPoi = na
var bool directionalFvgPoiAttempted = false
var string effectiveBiasDirection = biasDirection
var bool biasFlipped = false
var int biasFlippedAt = na
var float expansionLegOrigin = na
var float expansionLegTerminus = na
var int expansionLegOriginFormedAt = na
var SessionPoiTarget excludedContinuationPoi = na
var bool expansionLegInvalidationHandled = false
open_near_pwl = not na(dailyOpen) and not na(pwl) and math.abs(dailyOpen - pwl) <= syminfo.mintick * LABEL_GAP_TICKS * 4
pdRange = not na(pdh) and not na(pdl) ? pdh - pdl : na
pdEqLow = not na(pdRange) ? pdl + pdRange * 0.25 : na
pdEqHigh = not na(pdRange) ? pdl + pdRange * 0.75 : na
pdEq50 = not na(pdh) and not na(pdl) ? (pdh + pdl) / 2 : na
pd_eq_price = showPdEquilibrium50 ? pdEq50 : na
sessionOpenTime = f_daily_session_open_time()

weekKey = f_cme_week_session_key()
newRailWeek = not na(weekKey) and ta.change(weekKey) != 0

if sessionRolled
    sessionPoi := na
    continuationPoi := na
    directionalFvgPoiAttempted := false
    effectiveBiasDirection := biasDirection
    biasFlipped := false
    biasFlippedAt := na
    expansionLegOrigin := na
    expansionLegTerminus := na
    expansionLegOriginFormedAt := na
    excludedContinuationPoi := na
    expansionLegInvalidationHandled := false

if dailyBias == "Neutral" and na(sessionPoi)
    if pdhMitigated and pdlMitigated
        sessionPoi := pdhMitigatedTime <= pdlMitigatedTime ? SessionPoiTarget.new("pdh", pdhMitigatedTime, "PDH") : SessionPoiTarget.new("pdl", pdlMitigatedTime, "PDL")
    else if pdhMitigated
        sessionPoi := SessionPoiTarget.new("pdh", pdhMitigatedTime, "PDH")
    else if pdlMitigated
        sessionPoi := SessionPoiTarget.new("pdl", pdlMitigatedTime, "PDL")

bool pdhIsPoi = f_is_session_poi(sessionPoi, "pdh", pdhMitigatedTime, "PDH")
bool pdlIsPoi = f_is_session_poi(sessionPoi, "pdl", pdlMitigatedTime, "PDL")

adr_consumption_txt = not na(adrConsumptionPct) ? str.format("ADR {0,number,#.#}%", adrConsumptionPct) : "ADR"
[_open_plus_adr_line, _adr_consumption_label] = f_draw_level(open_plus_adr_line, adr_consumption_label, openPlusAdr, dailyOpenOriginBi, sessionEndBi, adr_consumption_txt, true, "above", SESSION_CONTEXT_COLOR)
open_plus_adr_line := _open_plus_adr_line
adr_consumption_label := _adr_consumption_label

[_open_minus_adr_line, _] = f_draw_level(open_minus_adr_line, na, openMinusAdr, dailyOpenOriginBi, sessionEndBi, "", true, "below", SESSION_CONTEXT_COLOR)
open_minus_adr_line := _open_minus_adr_line

[_pd_equilibrium_line, _pd_equilibrium_label] = f_draw_level(pd_equilibrium_line, pd_equilibrium_label, pd_eq_price, dailyOpenOriginBi, sessionEndBi, "PD EQ 50%", true, "on", SESSION_CONTEXT_COLOR)
pd_equilibrium_line := _pd_equilibrium_line
pd_equilibrium_label := _pd_equilibrium_label

chartTfSeconds = timeframe.in_seconds()
on4hChart = chartTfSeconds == 14400
on1hChart = chartTfSeconds == 3600
showFvgs = on4hChart or on1hChart
fvgLabel = on4hChart ? "4H FVG" : on1hChart ? "1H FVG" : ""

[formed, zoneLow, zoneHigh, formedTime, formedBullish] = f_detect_fvg()

var array<HtfFvgZone> activeFvgs = array.new<HtfFvgZone>()
var array<box> fvg_boxes = array.new<box>()
var array<label> fvg_labels = array.new<label>()
var int lastChartTf = na

if chartTfSeconds != lastChartTf
    array.clear(activeFvgs)
    lastChartTf := chartTfSeconds

if showFvgs
    [activeFvgsNext, _activeFvgsDirty] = f_advance_fvg_lifecycle(activeFvgs, formed, zoneLow, zoneHigh, formedTime, fvgLabel, formedBullish, close, time, barstate.isconfirmed)
    activeFvgs := activeFvgsNext

fvgZonesToDraw = showFvgs ? activeFvgs : array.new<HtfFvgZone>()

f_strict_fractal_high_confirmed(int pivot) =>
    float pivotHigh = high[pivot]
    pivotHigh > high[pivot + 1] and pivotHigh > high[pivot + 2] and pivotHigh > high[pivot + 3] and pivotHigh > high[pivot - 1] and pivotHigh > high[pivot - 2] and pivotHigh > high[pivot - 3]

f_strict_fractal_low_confirmed(int pivot) =>
    float pivotLow = low[pivot]
    pivotLow < low[pivot + 1] and pivotLow < low[pivot + 2] and pivotLow < low[pivot + 3] and pivotLow < low[pivot - 1] and pivotLow < low[pivot - 2] and pivotLow < low[pivot - 3]

f_swing_period_ms(string txt) =>
    str.contains(txt, "4H") ? 240 * 60 * 1000 : 60 * 60 * 1000

// When the chart TF is finer than the swing TF, anchor at the sub-bar wick time.
f_resolve_swing_wick_time(int htf_open, float price, string txt) =>
    int period_ms = f_swing_period_ms(txt)
    int chart_ms = timeframe.in_seconds() * 1000
    int result = htf_open
    if chart_ms < period_ms
        bool is_high = str.contains(txt, "High")
        int end_time = htf_open + period_ms
        int max_i = math.min(bar_index, BAR_TIME_SEARCH_MAX)
        for i = max_i to 0
            if time[i] >= htf_open and time[i] < end_time
                float extreme = is_high ? high[i] : low[i]
                if extreme == price
                    result := time[i]
                    break
    result

f_htf_swing_signals() =>
    bool highConfirmed = false
    float highPrice = na
    int highPivotTime = na
    int highConfirmedTime = na
    bool lowConfirmed = false
    float lowPrice = na
    int lowPivotTime = na
    int lowConfirmedTime = na
    int pivot = 3
    if barstate.isconfirmed
        if f_strict_fractal_high_confirmed(pivot)
            highConfirmed := true
            highPrice := high[pivot]
            highPivotTime := time[pivot]
            highConfirmedTime := time
        if f_strict_fractal_low_confirmed(pivot)
            lowConfirmed := true
            lowPrice := low[pivot]
            lowPivotTime := time[pivot]
            lowConfirmedTime := time
    [highConfirmed, highPrice, highPivotTime, highConfirmedTime, lowConfirmed, lowPrice, lowPivotTime, lowConfirmedTime]

f_htf_swing_and_fvg_signals() =>
    [highConfirmed, highPrice, highPivotTime, highConfirmedTime, lowConfirmed, lowPrice, lowPivotTime, lowConfirmedTime] = f_htf_swing_signals()
    [formed, zoneLow, zoneHigh, formedTime, bullish, barLow, barHigh, barTime, barClose] = f_detect_fvg_with_ohlc()
    [highConfirmed, highPrice, highPivotTime, highConfirmedTime, lowConfirmed, lowPrice, lowPivotTime, lowConfirmedTime, formed, zoneLow, zoneHigh, formedTime, bullish, barLow, barHigh, barTime, barClose]

f_swing_in_comparison_pool(HtfSwingLevel swing, int atTime, float pwh, float pwl, float curWeekHigh, float curWeekLow) =>
    if swing.confirmedTime > atTime or not f_within_htf_swing_comparison_lookback(swing.formedTime)
        false
    else
        float rangeLow = math.min(pwl, curWeekLow)
        float rangeHigh = math.max(pwh, curWeekHigh)
        swing.price >= rangeLow and swing.price <= rangeHigh

f_failure_swing_proximity(float adrVal, float adrPct) =>
    adrVal * (adrPct / 100.0)

f_same_swing_kind(string left, string right) =>
    (str.contains(left, "High") and str.contains(right, "High")) or (str.contains(left, "Low") and str.contains(right, "Low"))

f_is_more_extreme_swing(HtfSwingLevel swing, HtfSwingLevel other) =>
    bool isHigh = str.contains(swing.txt, "High")
    isHigh ? swing.price > other.price : swing.price < other.price

f_stamp_failure_swings(
     array<HtfSwingLevel> swings,
     int newIndex,
     float adrVal,
     float adrPct,
     float pwh,
     float pwl,
     float curWeekHigh,
     float curWeekLow
 ) =>
    HtfSwingLevel swing = array.get(swings, newIndex)
    if swing.isFailureSwing
        swings
    else
        float threshold = f_failure_swing_proximity(adrVal, adrPct)
        int count = array.size(swings)
        if count > 0
            for i = 0 to count - 1
                HtfSwingLevel peer = array.get(swings, i)
                bool inPool = f_same_swing_kind(swing.txt, peer.txt) and f_swing_in_comparison_pool(peer, swing.confirmedTime, pwh, pwl, curWeekHigh, curWeekLow) and not peer.mitigated and math.abs(peer.price - swing.price) <= threshold
                if inPool
                    if i != newIndex and not peer.isFailureSwing and f_is_more_extreme_swing(peer, swing)
                        array.set(swings, newIndex, HtfSwingLevel.new(swing.price, swing.formedTime, swing.confirmedTime, swing.txt, swing.mitigated, swing.mitigatedTime, true, swing.formedBi, swing.mitigatedBi))
                        break
                    if f_is_more_extreme_swing(swing, peer)
                        array.set(swings, i, HtfSwingLevel.new(peer.price, peer.formedTime, peer.confirmedTime, peer.txt, peer.mitigated, peer.mitigatedTime, true, peer.formedBi, peer.mitigatedBi))
        swings

f_swing_exists(array<HtfSwingLevel> swings, int formedTime, string txt) =>
    bool found = false
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel swing = array.get(swings, i)
            if swing.formedTime == formedTime and swing.txt == txt
                found := true
    found

f_cross_tf_swing_price_cluster(HtfSwingLevel fourH, HtfSwingLevel oneH, float threshold) =>
    f_same_swing_kind(fourH.txt, oneH.txt) and math.abs(fourH.price - oneH.price) <= threshold

f_canonical_cross_tf_swing_price(float left, float right, bool isHigh) =>
    isHigh ? math.max(left, right) : math.min(left, right)

f_is_inner_cross_tf_swing(bool isHigh, float price, float otherPrice) =>
    isHigh ? price < otherPrice : price > otherPrice

f_align_cross_tf_swing_prices(array<HtfSwingLevel> swings, float adrVal, float adrPct) =>
    float threshold = f_failure_swing_proximity(adrVal, adrPct)
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel fourH = array.get(swings, i)
            if not str.contains(fourH.txt, "4H")
                continue
            bool isHigh = str.contains(fourH.txt, "High")
            for j = 0 to count - 1
                if i == j
                    continue
                HtfSwingLevel oneH = array.get(swings, j)
                if not str.contains(oneH.txt, "1H") or not f_cross_tf_swing_price_cluster(fourH, oneH, threshold)
                    continue
                if fourH.confirmedTime > time or oneH.confirmedTime > time
                    continue
                float aligned = f_canonical_cross_tf_swing_price(fourH.price, oneH.price, isHigh)
                bool fourHInner = f_is_inner_cross_tf_swing(isHigh, fourH.price, oneH.price)
                bool oneHInner = f_is_inner_cross_tf_swing(isHigh, oneH.price, fourH.price)
                if fourHInner
                    array.set(swings, i, HtfSwingLevel.new(aligned, fourH.formedTime, fourH.confirmedTime, fourH.txt, fourH.mitigated, fourH.mitigatedTime, true, fourH.formedBi, fourH.mitigatedBi))
                    fourH := array.get(swings, i)
                if oneHInner
                    array.set(swings, j, HtfSwingLevel.new(aligned, oneH.formedTime, oneH.confirmedTime, oneH.txt, oneH.mitigated, oneH.mitigatedTime, true, oneH.formedBi, oneH.mitigatedBi))
                if not fourHInner and not oneHInner
                    array.set(swings, j, HtfSwingLevel.new(oneH.price, oneH.formedTime, oneH.confirmedTime, oneH.txt, oneH.mitigated, oneH.mitigatedTime, true, oneH.formedBi, oneH.mitigatedBi))
    swings

f_try_add_swing(
     array<HtfSwingLevel> swings,
     bool confirmed,
     float price,
     int formedTime,
     int confirmedTime,
     string txt,
     float pwh,
     float pwl,
     float curWeekHigh,
     float curWeekLow,
     float adrVal,
     float adrPct
 ) =>
    int resolvedFormedTime = f_resolve_swing_wick_time(formedTime, price, txt)
    if confirmed and not na(price) and not na(formedTime) and not na(confirmedTime) and f_swing_visible(price, formedTime, pwh, pwl, curWeekHigh, curWeekLow) and not f_swing_exists(swings, resolvedFormedTime, txt)
        array.push(swings, HtfSwingLevel.new(price, resolvedFormedTime, confirmedTime, txt, false, na, false, f_bar_index_for_time(resolvedFormedTime), na))
        f_stamp_failure_swings(swings, array.size(swings) - 1, adrVal, adrPct, pwh, pwl, curWeekHigh, curWeekLow)
        f_align_cross_tf_swing_prices(swings, adrVal, adrPct)
    swings

f_swing_swept(HtfSwingLevel swing, float checkLow, float checkHigh) =>
    bool isHigh = str.contains(swing.txt, "High")
    bool isLow = str.contains(swing.txt, "Low")
    (isHigh and checkHigh >= swing.price) or (isLow and checkLow <= swing.price)

f_sweep_swings(array<HtfSwingLevel> swings, float checkLow, float checkHigh, int checkTime) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if not swing.mitigated and checkTime > swing.confirmedTime and f_swing_swept(swing, checkLow, checkHigh)
            array.set(swings, i, HtfSwingLevel.new(swing.price, swing.formedTime, swing.confirmedTime, swing.txt, true, checkTime, swing.isFailureSwing, swing.formedBi, f_bar_index_for_time(checkTime)))
        i -= 1
    swings

f_sweep_swings_from_1m_bars(array<HtfSwingLevel> swings, array<float> checkLows, array<float> checkHighs, array<int> checkTimes) =>
    array<HtfSwingLevel> result = swings
    int count = array.size(checkTimes)
    if count > 0
        for j = 0 to count - 1
            result := f_sweep_swings(result, array.get(checkLows, j), array.get(checkHighs, j), array.get(checkTimes, j))
    result

f_remove_all_mitigated_swings(array<HtfSwingLevel> swings) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if swing.mitigated
            array.remove(swings, i)
        i -= 1
    swings

f_prune_stale_mitigated_swings(array<HtfSwingLevel> swings) =>
    int currentSession = f_cme_daily_session_key()
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if swing.mitigated
            int mitigatedSession = f_cme_daily_session_key_for(swing.mitigatedTime)
            if na(mitigatedSession) or mitigatedSession != currentSession
                array.remove(swings, i)
        i -= 1
    swings

f_prune_comparison_expired_swings(array<HtfSwingLevel> swings) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if not f_within_htf_swing_comparison_lookback(swing.formedTime)
            array.remove(swings, i)
        i -= 1
    swings

f_draw_swing_levels(
     array<line> existing_lines,
     array<label> existing_labels,
     array<HtfSwingLevel> swings,
     int session_end_bi,
     SessionPoiTarget session_poi,
     SessionPoiTarget tp1_target,
     SessionPoiTarget tp2_target,
     float pdh,
     float pdl,
     bool pdhMitigated,
     bool pdlMitigated,
     float pwh,
     float pwl,
     bool pwhMitigated,
     bool pwlMitigated,
     float curWeekHigh,
     float curWeekLow,
     bool in_continuation_regime
 ) =>
    array<line> next_lines = array.new<line>()
    array<label> next_labels = array.new<label>()
    if barstate.islast
        int line_count = array.size(existing_lines)
        if line_count > 0
            for i = 0 to line_count - 1
                line.delete(array.get(existing_lines, i))
        int label_count = array.size(existing_labels)
        if label_count > 0
            for i = 0 to label_count - 1
                label.delete(array.get(existing_labels, i))
        int swing_count = array.size(swings)
        if swing_count > 0
            for drawRank = 1 to 2
                for i = 0 to swing_count - 1
                    HtfSwingLevel swing = array.get(swings, i)
                    if swing.isFailureSwing
                        continue
                    if not f_swing_visible(swing.price, swing.formedTime, pwh, pwl, curWeekHigh, curWeekLow)
                        continue
                    if f_timeframe_rank(swing.txt) != drawRank
                        continue
                    int origin_bi = swing.formedBi
                    int end_bi = swing.mitigated ? math.max(origin_bi, swing.mitigatedBi) : math.max(origin_bi, session_end_bi)
                    bool is_poi = not in_continuation_regime and f_is_session_poi(session_poi, "swing", swing.formedTime, swing.txt)
                    bool is_tp1 = f_is_active_dol(tp1_target, "swing", swing.formedTime, swing.txt)
                    bool is_tp2 = f_is_active_dol(tp2_target, "swing", swing.formedTime, swing.txt)
                    bool is_dol = is_tp1 or is_tp2
                    color line_color = swing.mitigated ? SWING_MITIGATED_COLOR : is_poi ? POI_COLOR : is_dol ? DOL_COLOR : LEVEL_COLOR
                    int line_width = is_poi or is_dol ? POI_LINE_WIDTH : 1
                    line next_line = line.new(
                         origin_bi,
                         swing.price,
                         end_bi,
                         swing.price,
                         xloc = xloc.bar_index,
                         extend = extend.none,
                         color = line_color,
                         width = line_width,
                         style = line.style_solid
                     )
                    array.push(next_lines, next_line)
                    if not swing.mitigated and not f_swing_label_suppressed_by_higher_tf(swings, swing) and not f_swing_label_suppressed_by_liquidity_rail(swing, pdh, pdl, pdhMitigated, pdlMitigated, pwh, pwl, pwhMitigated, pwlMitigated)
                        string label_txt = f_format_level_label(swing.txt, is_poi, false, is_tp1, is_tp2)
                        label next_label = label.new(
                             end_bi,
                             f_label_y(swing.price, "on"),
                             label_txt,
                             xloc = xloc.bar_index,
                             style = label.style_label_left,
                             color = color(na),
                             textcolor = line_color,
                             size = LABEL_SIZE
                         )
                        array.push(next_labels, next_label)
    [next_lines, next_labels]

[
     highConfirmed4h,
     highPrice4h,
     highPivotTime4h,
     highConfirmedTime4h,
     lowConfirmed4h,
     lowPrice4h,
     lowPivotTime4h,
     lowConfirmedTime4h,
     formed4h,
     zoneLow4h,
     zoneHigh4h,
     formedTime4h,
     bullish4h,
     low4h,
     high4h,
     time4h,
     close4h
 ] = request.security(
     syminfo.tickerid,
     "240",
     f_htf_swing_and_fvg_signals(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[
     highConfirmed1h,
     highPrice1h,
     highPivotTime1h,
     highConfirmedTime1h,
     lowConfirmed1h,
     lowPrice1h,
     lowPivotTime1h,
     lowConfirmedTime1h,
     formed1h,
     zoneLow1h,
     zoneHigh1h,
     formedTime1h,
     bullish1h,
     low1h,
     high1h,
     time1h,
     close1h
 ] = request.security(
     syminfo.tickerid,
     "60",
     f_htf_swing_and_fvg_signals(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

var array<HtfFvgZone> poiFvgs4h = array.new<HtfFvgZone>()
var array<HtfFvgZone> poiFvgs1h = array.new<HtfFvgZone>()
var array<HtfFvgZone> allPoiFvgs = array.new<HtfFvgZone>()

var array<HtfSwingLevel> activeSwings = array.new<HtfSwingLevel>()
var array<line> swing_lines = array.new<line>()
var array<label> swing_labels = array.new<label>()

if newRailWeek
    activeSwings := f_prune_comparison_expired_swings(activeSwings)

if sessionRolled
    activeSwings := f_remove_all_mitigated_swings(activeSwings)

activeSwings := f_try_add_swing(activeSwings, highConfirmed4h, highPrice4h, highPivotTime4h, highConfirmedTime4h, "4H Swing High", pwh, pwl, currentWeekHigh, currentWeekLow, adr, failureSwingAdrPct)
activeSwings := f_try_add_swing(activeSwings, lowConfirmed4h, lowPrice4h, lowPivotTime4h, lowConfirmedTime4h, "4H Swing Low", pwh, pwl, currentWeekHigh, currentWeekLow, adr, failureSwingAdrPct)
activeSwings := f_try_add_swing(activeSwings, highConfirmed1h, highPrice1h, highPivotTime1h, highConfirmedTime1h, "1H Swing High", pwh, pwl, currentWeekHigh, currentWeekLow, adr, failureSwingAdrPct)
activeSwings := f_try_add_swing(activeSwings, lowConfirmed1h, lowPrice1h, lowPivotTime1h, lowConfirmedTime1h, "1H Swing Low", pwh, pwl, currentWeekHigh, currentWeekLow, adr, failureSwingAdrPct)
activeSwings := f_sweep_swings_from_1m_bars(activeSwings, oneMinLows, oneMinHighs, oneMinTimes)
activeSwings := f_prune_stale_mitigated_swings(activeSwings)
activeSwings := f_prune_comparison_expired_swings(activeSwings)

bool poiFvgsDirty = false
[poiFvgs4hNext, poiFvgs4hDirty] = f_advance_fvg_lifecycle(poiFvgs4h, formed4h, zoneLow4h, zoneHigh4h, formedTime4h, "4H FVG", bullish4h, close4h, time4h, barstate.isconfirmed)
poiFvgs4h := poiFvgs4hNext
poiFvgsDirty := poiFvgs4hDirty
[poiFvgs1hNext, poiFvgs1hDirty] = f_advance_fvg_lifecycle(poiFvgs1h, formed1h, zoneLow1h, zoneHigh1h, formedTime1h, "1H FVG", bullish1h, close1h, time1h, barstate.isconfirmed)
poiFvgs1h := poiFvgs1hNext
poiFvgsDirty := poiFvgsDirty or poiFvgs1hDirty
if poiFvgsDirty
    allPoiFvgs := f_concat_fvg_arrays(poiFvgs4h, poiFvgs1h)

if dailyBias == "Directional" and not biasFlipped and not na(pdEq50) and time >= sessionOpenTime
    bool bearishBias = effectiveBiasDirection == "Bearish"
    bool htf1hClosed = ta.change(time1h) != 0
    bool htf4hClosed = ta.change(time4h) != 0
    if htf1hClosed and time1h[1] >= sessionOpenTime and f_close_through_pd_midpoint_against_bias(bearishBias, close1h[1], pdEq50)
        effectiveBiasDirection := bearishBias ? "Bullish" : "Bearish"
        biasFlipped := true
        biasFlippedAt := time1h[1]
        sessionPoi := na
        continuationPoi := na
        excludedContinuationPoi := na
        expansionLegInvalidationHandled := false
        HtfSwingLevel originSwing = f_find_opposing_1h_swing_before_flip(activeSwings, biasFlippedAt, effectiveBiasDirection == "Bullish")
        if not na(originSwing)
            expansionLegOrigin := originSwing.price
            expansionLegOriginFormedAt := originSwing.formedTime
            expansionLegTerminus := originSwing.price
        else
            expansionLegOrigin := na
            expansionLegOriginFormedAt := na
            expansionLegTerminus := na
    else if htf4hClosed and time4h[1] >= sessionOpenTime and f_close_through_pd_midpoint_against_bias(bearishBias, close4h[1], pdEq50)
        effectiveBiasDirection := bearishBias ? "Bullish" : "Bearish"
        biasFlipped := true
        biasFlippedAt := time4h[1]
        sessionPoi := na
        continuationPoi := na
        excludedContinuationPoi := na
        expansionLegInvalidationHandled := false
        HtfSwingLevel originSwing = f_find_opposing_1h_swing_before_flip(activeSwings, biasFlippedAt, effectiveBiasDirection == "Bullish")
        if not na(originSwing)
            expansionLegOrigin := originSwing.price
            expansionLegOriginFormedAt := originSwing.formedTime
            expansionLegTerminus := originSwing.price
        else
            expansionLegOrigin := na
            expansionLegOriginFormedAt := na
            expansionLegTerminus := na

bool htf1hClosedForLeg = ta.change(time1h) != 0
if biasFlipped and not na(expansionLegOriginFormedAt) and htf1hClosedForLeg and time1h[1] >= sessionOpenTime and time1h[1] >= expansionLegOriginFormedAt
    if effectiveBiasDirection == "Bullish"
        expansionLegTerminus := math.max(expansionLegTerminus, high1h[1])
    else
        expansionLegTerminus := math.min(expansionLegTerminus, low1h[1])

if biasFlipped and not expansionLegInvalidationHandled and not na(biasFlippedAt) and not na(expansionLegOrigin) and htf1hClosedForLeg and time1h[1] > biasFlippedAt and f_closes_past_expansion_leg_midpoint(close1h[1], expansionLegOrigin, expansionLegTerminus, effectiveBiasDirection == "Bullish")
    float priceBeforeInvalidation = close1h[2]
    excludedContinuationPoi := f_select_continuation_fvg_poi(allPoiFvgs, expansionLegOrigin, expansionLegTerminus, sessionOpenTime, time1h[1], priceBeforeInvalidation, effectiveBiasDirection == "Bullish", na)
    expansionLegInvalidationHandled := true

if dailyBias == "Directional" and biasFlipped and not na(expansionLegOrigin)
    continuationPoi := f_select_continuation_fvg_poi(allPoiFvgs, expansionLegOrigin, expansionLegTerminus, sessionOpenTime, time, close, effectiveBiasDirection == "Bullish", excludedContinuationPoi)

if dailyBias == "Directional" and not biasFlipped and not directionalFvgPoiAttempted and time >= sessionOpenTime and not na(pdEq50)
    sessionPoi := f_select_directional_fvg_poi(allPoiFvgs, pdEq50, effectiveBiasDirection == "Bullish", sessionOpenTime, close)
    directionalFvgPoiAttempted := true

if dailyBias == "Directional" and not biasFlipped and directionalFvgPoiAttempted and na(sessionPoi)
    sessionPoi := f_select_defer_swing_poi(activeSwings, sessionOpenTime, close, time, pwh, pwl, currentWeekHigh, currentWeekLow, pdEq50, effectiveBiasDirection == "Bullish")

if not na(sessionPoi) and f_poi_target_mitigated(sessionPoi, allPoiFvgs, activeSwings)
    sessionPoi := na

bool bullishBias = effectiveBiasDirection == "Bullish"
[activeDolTp1, activeDolTp2] = f_resolve_active_dol(bullishBias, close, dailyOpen, adrConsumptionPct, reversalDayTp1, openPlusAdr, openMinusAdr, pdh, pdl, pwh, pwl, pdhMitigated, pdlMitigated, pwhMitigated, pwlMitigated, currentWeekHigh, currentWeekLow, activeSwings)

bool dailyOpenIsTp1 = f_is_active_dol(activeDolTp1, "daily-open", na, "Daily Open")
[_daily_open_line, _daily_open_label] = f_draw_level(daily_open_line, daily_open_label, dailyOpen, dailyOpenOriginBi, sessionEndBi, "Daily Open", true, "above", SESSION_CONTEXT_COLOR, false, na, false, dailyOpenIsTp1, false, true)
daily_open_line := _daily_open_line
daily_open_label := _daily_open_label

bool pdhIsTp1 = f_is_active_dol(activeDolTp1, "pdh", pdhMitigatedTime, "PDH")
bool pdhIsTp2 = f_is_active_dol(activeDolTp2, "pdh", pdhMitigatedTime, "PDH")
bool pdhLabelSuppressed = f_daily_rail_label_suppressed("pdh", pdh, pwh, pwl, pwhMitigated, pwlMitigated)
[_pdh_line, _pdh_label] = f_draw_level(pdh_line, pdh_label, pdh, pdhOriginBi, sessionEndBi, "PDH", false, "on", LEVEL_COLOR, pdhMitigated, pdhMitigatedBi, pdhIsPoi, pdhIsTp1, pdhIsTp2, false, pdhLabelSuppressed)
pdh_line := _pdh_line
pdh_label := _pdh_label

bool pdlIsTp1 = f_is_active_dol(activeDolTp1, "pdl", pdlMitigatedTime, "PDL")
bool pdlIsTp2 = f_is_active_dol(activeDolTp2, "pdl", pdlMitigatedTime, "PDL")
bool pdlLabelSuppressed = f_daily_rail_label_suppressed("pdl", pdl, pwh, pwl, pwhMitigated, pwlMitigated)
[_pdl_line, _pdl_label] = f_draw_level(pdl_line, pdl_label, pdl, pdlOriginBi, sessionEndBi, "PDL", false, "on", LEVEL_COLOR, pdlMitigated, pdlMitigatedBi, pdlIsPoi, pdlIsTp1, pdlIsTp2, false, pdlLabelSuppressed)
pdl_line := _pdl_line
pdl_label := _pdl_label

bool pwhIsTp1 = f_is_active_dol(activeDolTp1, "pwh", pwhMitigatedTime, "PWH")
bool pwhIsTp2 = f_is_active_dol(activeDolTp2, "pwh", pwhMitigatedTime, "PWH")
[_pwh_line, _pwh_label] = f_draw_level(pwh_line, pwh_label, pwh, pwhOriginBi, sessionEndBi, "PWH", false, "on", LEVEL_COLOR, pwhMitigated, pwhMitigatedBi, false, pwhIsTp1, pwhIsTp2)
pwh_line := _pwh_line
pwh_label := _pwh_label

bool pwlIsTp1 = f_is_active_dol(activeDolTp1, "pwl", pwlMitigatedTime, "PWL")
bool pwlIsTp2 = f_is_active_dol(activeDolTp2, "pwl", pwlMitigatedTime, "PWL")
[_pwl_line, _pwl_label] = f_draw_level(pwl_line, pwl_label, pwl, pwlOriginBi, sessionEndBi, "PWL", false, open_near_pwl ? "below" : "on", LEVEL_COLOR, pwlMitigated, pwlMitigatedBi, false, pwlIsTp1, pwlIsTp2)
pwl_line := _pwl_line
pwl_label := _pwl_label

bool inContinuationRegime = biasFlipped

[_fvg_boxes, _fvg_labels] = f_draw_fvg_zones(fvg_boxes, fvg_labels, fvgZonesToDraw, sessionEndBi, sessionPoi, continuationPoi, inContinuationRegime)
fvg_boxes := _fvg_boxes
fvg_labels := _fvg_labels

[_swing_lines, _swing_labels] = f_draw_swing_levels(swing_lines, swing_labels, activeSwings, sessionEndBi, sessionPoi, activeDolTp1, activeDolTp2, pdh, pdl, pdhMitigated, pdlMitigated, pwh, pwl, pwhMitigated, pwlMitigated, currentWeekHigh, currentWeekLow, inContinuationRegime)
swing_lines := _swing_lines
swing_labels := _swing_labels
