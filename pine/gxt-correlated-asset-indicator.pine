//@version=6
indicator(
     "GxT Correlated Asset Indicator",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500,
     dynamic_requests = false
 )

TZ = "America/New_York"
SESSION_HOUR = 18
WEEKLY_END_HOUR = 17
LEVEL_COLOR = color.black
SWING_MITIGATED_COLOR = color.new(color.gray, 35)
SESSION_CONTEXT_COLOR = color.new(color.gray, 30)
FVG_COLOR = color.new(color.teal, 85)
POI_COLOR = color.new(color.orange, 0)
POI_FVG_COLOR = color.new(color.orange, 70)
POI_FVG_BORDER = color.new(color.orange, 15)
POI_LINE_WIDTH = 2
DOL_COLOR = color.new(color.purple, 0)
DOL_FVG_COLOR = color.new(color.purple, 70)
DOL_FVG_BORDER = color.new(color.purple, 15)
DOL_LINE_WIDTH = 2
LABEL_SIZE = size.small
LABEL_GAP_TICKS = 2
ADR_LOOKBACK = 14
BAR_TIME_SEARCH_MAX = 4999

// f_bar_index_for_time scans time[] on barstate.islast (realtime). Without an explicit
// buffer, Pine auto-sizes too small on the last bar and throws CE overflow errors.
max_bars_back(time, BAR_TIME_SEARCH_MAX + 1)

showPdEquilibrium50 = input.bool(true, "Show PD 50% Equilibrium", group = "Session Context")
dailyBias = input.string("Directional", "Daily Bias", options = ["Directional", "Neutral"], group = "Session POI")
biasDirection = input.string("Bullish", "Bias Direction", options = ["Bullish", "Bearish"], group = "Active DOL")
reversalDayTp1 = input.bool(false, "Reversal Day TP1", group = "Active DOL")

f_cme_daily_session_key_for(int t) =>
    et_hour = hour(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    if et_hour >= SESSION_HOUR
        timestamp(TZ, y, m, d, 0, 0)
    else
        timestamp(TZ, y, m, d, 0, 0) - 86400000

f_cme_daily_session_key() =>
    f_cme_daily_session_key_for(time)

f_daily_session_open_time() =>
    int session_day = f_cme_daily_session_key()
    y = year(session_day, TZ)
    m = month(session_day, TZ)
    d = dayofmonth(session_day, TZ)
    timestamp(TZ, y, m, d, SESSION_HOUR, 0)

f_current_daily_session_end() =>
    session_start_day = f_cme_daily_session_key()
    y = year(session_start_day, TZ)
    m = month(session_start_day, TZ)
    d = dayofmonth(session_start_day, TZ)
    timestamp(TZ, y, m, d + 1, WEEKLY_END_HOUR, 0)

f_in_cme_week() =>
    dow = dayofweek(time, TZ)
    et_hour = hour(time, TZ)
    et_minute = minute(time, TZ)
    sun_evening = dow == dayofweek.sunday and et_hour >= SESSION_HOUR
    mid_week = dow > dayofweek.sunday and dow < dayofweek.friday
    fri_close = dow == dayofweek.friday and (et_hour < WEEKLY_END_HOUR or (et_hour == WEEKLY_END_HOUR and et_minute == 0))
    sun_evening or mid_week or fri_close

f_in_cme_week_for(int t) =>
    dow = dayofweek(t, TZ)
    et_hour = hour(t, TZ)
    et_minute = minute(t, TZ)
    sun_evening = dow == dayofweek.sunday and et_hour >= SESSION_HOUR
    mid_week = dow > dayofweek.sunday and dow < dayofweek.friday
    fri_close = dow == dayofweek.friday and (et_hour < WEEKLY_END_HOUR or (et_hour == WEEKLY_END_HOUR and et_minute == 0))
    sun_evening or mid_week or fri_close

f_cme_week_session_key_for(int t) =>
    dow = dayofweek(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    offset = dow - 1
    sun_day = d - offset
    f_in_cme_week_for(t) ? timestamp(TZ, y, m, sun_day, SESSION_HOUR, 0) : na

f_cme_week_session_key() =>
    f_cme_week_session_key_for(time)

f_week_start_for(int t) =>
    dow = dayofweek(t, TZ)
    y = year(t, TZ)
    m = month(t, TZ)
    d = dayofmonth(t, TZ)
    offset = dow - 1
    sun_day = d - offset
    timestamp(TZ, y, m, sun_day, SESSION_HOUR, 0)

f_week_end_for(int week_start) =>
    y = year(week_start, TZ)
    m = month(week_start, TZ)
    d = dayofmonth(week_start, TZ)
    timestamp(TZ, y, m, d + 5, WEEKLY_END_HOUR, 0)

f_resolve_week_session_key(int t) =>
    int direct = f_cme_week_session_key_for(t)
    if not na(direct)
        direct
    else
        int week_start = f_week_start_for(t)
        int week_end = f_week_end_for(week_start)
        t > week_end ? week_start : week_start - 7 * 86400000

f_previous_week_session_key(int week_key) =>
    week_key - 7 * 86400000

f_previous_daily_session_key(int session_key) =>
    session_key - 86400000

f_is_cme_holiday(int day_key) =>
    day_key == timestamp(TZ, 2025, 1, 20, 0, 0)

f_is_first_daily_session_of_cme_week(int session_key) =>
    int dow = dayofweek(session_key, TZ)
    bool is_monday = dow == dayofweek.monday
    bool is_tuesday_after_holiday = dow == dayofweek.tuesday and f_is_cme_holiday(session_key - 86400000)
    is_monday or is_tuesday_after_holiday

f_prior_friday_daily_session_key(int session_key) =>
    int dow = dayofweek(session_key, TZ)
    int week_sunday = dow == dayofweek.monday ? session_key - 86400000 : session_key - 2 * 86400000
    int friday = week_sunday - 2 * 86400000
    friday - 86400000

f_within_htf_fvg_lookback(int formedTime) =>
    int formedSession = f_cme_daily_session_key_for(formedTime)
    int asOfSession = f_cme_daily_session_key_for(time)
    if na(formedSession) or na(asOfSession)
        false
    else
        bool current = formedSession == asOfSession
        bool previous = formedSession == f_previous_daily_session_key(asOfSession)
        bool friday_bridge = f_is_first_daily_session_of_cme_week(asOfSession) and formedSession == f_prior_friday_daily_session_key(asOfSession)
        current or previous or friday_bridge

f_within_htf_swing_lookback(int formedTime) =>
    int formedWeek = f_resolve_week_session_key(formedTime)
    int asOfWeek = f_resolve_week_session_key(time)
    if na(formedWeek) or na(asOfWeek)
        false
    else
        formedWeek == asOfWeek or formedWeek == f_previous_week_session_key(asOfWeek)

f_track_extreme(float cur_extreme, int cur_time, float candidate, int candidate_time) =>
    if na(cur_extreme) or candidate > cur_extreme
        [candidate, candidate_time]
    else
        [cur_extreme, cur_time]

f_track_extreme_low(float cur_extreme, int cur_time, float candidate, int candidate_time) =>
    if na(cur_extreme) or candidate < cur_extreme
        [candidate, candidate_time]
    else
        [cur_extreme, cur_time]

f_session_rails() =>
    var float cur_daily_high = na
    var float cur_daily_low = na
    var int cur_daily_high_time = na
    var int cur_daily_low_time = na
    var float cur_week_high = na
    var float cur_week_low = na
    var int cur_week_high_time = na
    var int cur_week_low_time = na
    var float out_pdh = na
    var float out_pdl = na
    var int out_pdh_time = na
    var int out_pdl_time = na
    var float out_pwh = na
    var float out_pwl = na
    var int out_pwh_time = na
    var int out_pwl_time = na
    var float out_daily_open = na
    var int out_daily_open_time = na
    var array<float> completed_daily_ranges = array.new_float(0)

    daily_key = f_cme_daily_session_key()
    week_key = f_cme_week_session_key()
    new_daily = ta.change(daily_key) != 0
    week_key_change = ta.change(week_key)
    new_week = not na(week_key) and week_key_change != 0

    if new_daily
        if not na(cur_daily_high)
            out_pdh := cur_daily_high
            out_pdl := cur_daily_low
            out_pdh_time := cur_daily_high_time
            out_pdl_time := cur_daily_low_time
            array.push(completed_daily_ranges, cur_daily_high - cur_daily_low)
            if array.size(completed_daily_ranges) > ADR_LOOKBACK
                array.shift(completed_daily_ranges)
        cur_daily_high := high
        cur_daily_low := low
        cur_daily_high_time := time
        cur_daily_low_time := time
        out_daily_open := open
        out_daily_open_time := time
    else
        [next_high, next_high_time] = f_track_extreme(cur_daily_high, cur_daily_high_time, high, time)
        [next_low, next_low_time] = f_track_extreme_low(cur_daily_low, cur_daily_low_time, low, time)
        cur_daily_high := next_high
        cur_daily_high_time := next_high_time
        cur_daily_low := next_low
        cur_daily_low_time := next_low_time

    if not na(week_key)
        if new_week
            if not na(cur_week_high)
                out_pwh := cur_week_high
                out_pwl := cur_week_low
                out_pwh_time := cur_week_high_time
                out_pwl_time := cur_week_low_time
            cur_week_high := high
            cur_week_low := low
            cur_week_high_time := time
            cur_week_low_time := time
        else
            [next_week_high, next_week_high_time] = f_track_extreme(cur_week_high, cur_week_high_time, high, time)
            [next_week_low, next_week_low_time] = f_track_extreme_low(cur_week_low, cur_week_low_time, low, time)
            cur_week_high := next_week_high
            cur_week_high_time := next_week_high_time
            cur_week_low := next_week_low
            cur_week_low_time := next_week_low_time

    float out_adr = na
    int range_count = array.size(completed_daily_ranges)
    if range_count > 0
        float range_sum = 0.0
        for i = 0 to range_count - 1
            range_sum += array.get(completed_daily_ranges, i)
        out_adr := range_sum / range_count

    float out_open_plus_adr = not na(out_daily_open) and not na(out_adr) ? out_daily_open + out_adr : na
    float out_open_minus_adr = not na(out_daily_open) and not na(out_adr) ? out_daily_open - out_adr : na
    float current_daily_range = not na(cur_daily_high) and not na(cur_daily_low) ? cur_daily_high - cur_daily_low : na
    float out_adr_consumption_pct = not na(current_daily_range) and not na(out_adr) and out_adr > 0 ? current_daily_range / out_adr * 100.0 : na

    [out_pdh, out_pdl, out_pwh, out_pwl, out_daily_open, out_pdh_time, out_pdl_time, out_pwh_time, out_pwl_time, out_daily_open_time, out_adr, out_open_plus_adr, out_open_minus_adr, out_adr_consumption_pct, cur_week_high, cur_week_low]

[pdh, pdl, pwh, pwl, dailyOpen, pdhTime, pdlTime, pwhTime, pwlTime, dailyOpenTime, adr, openPlusAdr, openMinusAdr, adrConsumptionPct, currentWeekHigh, currentWeekLow] = request.security(
     syminfo.tickerid,
     "1",
     f_session_rails(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

sessionEnd = request.security(
     syminfo.tickerid,
     "1",
     f_current_daily_session_end(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[oneMinLow, oneMinHigh, oneMinTime] = request.security(
     syminfo.tickerid,
     "1",
     [low, high, time],
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

dailySessionKey = f_cme_daily_session_key()
var int prevDailySessionKey = na
sessionRolled = not na(dailySessionKey) and not na(prevDailySessionKey) and dailySessionKey != prevDailySessionKey
prevDailySessionKey := dailySessionKey

f_label_y(float price, string placement) =>
    gap = syminfo.mintick * LABEL_GAP_TICKS
    placement == "above" ? price + gap : placement == "below" ? price - gap : price

f_label_style(string placement) =>
    placement == "above" ? label.style_label_up : placement == "below" ? label.style_label_down : label.style_label_left

type HtfFvgZone
    float zoneLow
    float zoneHigh
    int formedTime
    string txt
    bool bullish
    bool mitigated
    int mitigatedTime

type HtfSwingLevel
    float price
    int formedTime
    int confirmedTime
    string txt
    bool mitigated
    int mitigatedTime

type SessionPoiTarget
    string kind
    int formedTime
    string txt

f_fvg_overlaps_equilibrium(float zoneLow, float zoneHigh, float eqLow, float eqHigh) =>
    zoneLow <= eqHigh and zoneHigh >= eqLow

f_timeframe_rank(string txt) =>
    str.contains(txt, "4H") ? 2 : 1

f_same_level_price(float left, float right) =>
    math.abs(left - right) <= syminfo.mintick / 2

f_swing_label_suppressed_by_higher_tf(array<HtfSwingLevel> swings, HtfSwingLevel swing) =>
    bool suppressed = false
    float swingRank = f_timeframe_rank(swing.txt)
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel other = array.get(swings, i)
            if not other.mitigated and f_timeframe_rank(other.txt) > swingRank and f_same_level_price(other.price, swing.price)
                suppressed := true
                break
    suppressed

f_daily_rail_label_suppressed(string kind, float price, float pwh, float pwl, bool pwhMitigated, bool pwlMitigated) =>
    bool suppressed = false
    if kind == "pdh" and not pwhMitigated and not na(pwh) and f_same_level_price(price, pwh)
        suppressed := true
    if kind == "pdl" and not pwlMitigated and not na(pwl) and f_same_level_price(price, pwl)
        suppressed := true
    suppressed

f_swing_label_suppressed_by_liquidity_rail(
     HtfSwingLevel swing,
     float pdh,
     float pdl,
     bool pdhMitigated,
     bool pdlMitigated,
     float pwh,
     float pwl,
     bool pwhMitigated,
     bool pwlMitigated
 ) =>
    bool isHigh = str.contains(swing.txt, "High")
    bool isLow = str.contains(swing.txt, "Low")
    bool suppressed = false
    if isHigh
        if not pdhMitigated and not na(pdh) and f_same_level_price(swing.price, pdh)
            suppressed := true
        if not pwhMitigated and not na(pwh) and f_same_level_price(swing.price, pwh)
            suppressed := true
    if isLow
        if not pdlMitigated and not na(pdl) and f_same_level_price(swing.price, pdl)
            suppressed := true
        if not pwlMitigated and not na(pwl) and f_same_level_price(swing.price, pwl)
            suppressed := true
    suppressed

f_is_session_poi(SessionPoiTarget poi, string kind, int formedTime, string txt) =>
    bool matches = not na(poi) and poi.kind == kind and poi.txt == txt
    kind == "pdh" or kind == "pdl" or kind == "pwh" or kind == "pwl" ? matches : matches and poi.formedTime == formedTime

f_select_directional_fvg_poi(
     array<HtfFvgZone> zones,
     float eqLow,
     float eqHigh,
     int sessionOpenTime,
     float currentPrice
 ) =>
    SessionPoiTarget best = na
    float bestRank = na
    float bestDistance = na
    int count = array.size(zones)
    if count > 0
        for i = 0 to count - 1
            HtfFvgZone zone = array.get(zones, i)
            bool eligible = not zone.mitigated and zone.formedTime <= sessionOpenTime and f_fvg_overlaps_equilibrium(zone.zoneLow, zone.zoneHigh, eqLow, eqHigh)
            if eligible
                float mid = (zone.zoneLow + zone.zoneHigh) / 2.0
                float dist = math.abs(currentPrice - mid)
                float rank = f_timeframe_rank(zone.txt)
                bool take = na(best) or rank > bestRank or (rank == bestRank and dist < bestDistance)
                if take
                    best := SessionPoiTarget.new("fvg", zone.formedTime, zone.txt)
                    bestRank := rank
                    bestDistance := dist
    best

f_select_defer_swing_poi(
     array<HtfSwingLevel> swings,
     int sessionOpenTime,
     float currentPrice,
     int asOfTime
 ) =>
    SessionPoiTarget best = na
    float bestRank = na
    float bestDistance = na
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel swing = array.get(swings, i)
            bool eligible = not swing.mitigated and swing.confirmedTime >= sessionOpenTime and swing.confirmedTime <= asOfTime
            if eligible
                float dist = math.abs(currentPrice - swing.price)
                float rank = f_timeframe_rank(swing.txt)
                bool take = na(best) or rank > bestRank or (rank == bestRank and dist < bestDistance)
                if take
                    best := SessionPoiTarget.new("swing", swing.formedTime, swing.txt)
                    bestRank := rank
                    bestDistance := dist
    best

f_format_level_label(string txt, bool is_poi, bool is_tp1, bool is_tp2) =>
    string label_txt = txt
    if is_poi
        label_txt += " · POI"
    if is_tp1
        label_txt += " · TP1"
    if is_tp2
        label_txt += " · TP2"
    label_txt

f_is_active_dol(SessionPoiTarget target, string kind, int formedTime, string txt) =>
    bool matches = not na(target) and target.kind == kind and target.txt == txt
    kind == "daily-open" or kind == "pdh" or kind == "pdl" or kind == "pwh" or kind == "pwl" ? matches : matches and target.formedTime == formedTime

f_dol_in_bias_direction(bool bullish, float currentPrice, float levelPrice) =>
    bullish ? levelPrice > currentPrice : levelPrice < currentPrice

f_dol_within_adr(bool bullish, float levelPrice, float openPlusAdr, float openMinusAdr) =>
    bullish ? levelPrice <= openPlusAdr : levelPrice >= openMinusAdr

f_dol_distance(float currentPrice, float levelPrice) =>
    math.abs(currentPrice - levelPrice)

f_dol_tier(string kind) =>
    kind == "pwh" or kind == "pwl" ? 3 : kind == "pdh" or kind == "pdl" ? 2 : 1

f_update_nearest_dol(
     SessionPoiTarget best,
     float bestDistance,
     SessionPoiTarget candidate,
     float candidatePrice,
     float currentPrice
 ) =>
    float dist = f_dol_distance(currentPrice, candidatePrice)
    bool take = na(best) or dist < bestDistance
    [take ? candidate : best, take ? dist : bestDistance]

f_update_furthest_dol(
     SessionPoiTarget best,
     float bestDistance,
     int bestTier,
     SessionPoiTarget candidate,
     float candidatePrice,
     float currentPrice
 ) =>
    float dist = f_dol_distance(currentPrice, candidatePrice)
    int tier = f_dol_tier(candidate.kind)
    bool take = na(best) or dist > bestDistance or (dist == bestDistance and tier > bestTier)
    [take ? candidate : best, take ? dist : bestDistance, take ? tier : bestTier]

f_resolve_active_dol(
     bool bullish,
     float currentPrice,
     float dailyOpen,
     float adrConsumptionPct,
     bool reversalDayTp1Enabled,
     float openPlusAdr,
     float openMinusAdr,
     float pdh,
     float pdl,
     float pwh,
     float pwl,
     bool pdhMitigated,
     bool pdlMitigated,
     bool pwhMitigated,
     bool pwlMitigated,
     array<HtfFvgZone> zones,
     array<HtfSwingLevel> swings
 ) =>
    SessionPoiTarget nearest = na
    float nearestDistance = na
    SessionPoiTarget furthest = na
    float furthestDistance = na
    int furthestTier = na

    if not pdhMitigated and not na(pdh) and f_dol_in_bias_direction(bullish, currentPrice, pdh)
        SessionPoiTarget candidate = SessionPoiTarget.new("pdh", na, "PDH")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pdh, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pdh, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pdh, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pdlMitigated and not na(pdl) and f_dol_in_bias_direction(bullish, currentPrice, pdl)
        SessionPoiTarget candidate = SessionPoiTarget.new("pdl", na, "PDL")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pdl, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pdl, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pdl, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pwhMitigated and not na(pwh) and f_dol_in_bias_direction(bullish, currentPrice, pwh)
        SessionPoiTarget candidate = SessionPoiTarget.new("pwh", na, "PWH")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pwh, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pwh, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pwh, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    if not pwlMitigated and not na(pwl) and f_dol_in_bias_direction(bullish, currentPrice, pwl)
        SessionPoiTarget candidate = SessionPoiTarget.new("pwl", na, "PWL")
        [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, pwl, currentPrice)
        nearest := nextNearest
        nearestDistance := nextNearestDistance
        if f_dol_within_adr(bullish, pwl, openPlusAdr, openMinusAdr)
            [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, pwl, currentPrice)
            furthest := nextFurthest
            furthestDistance := nextFurthestDistance
            furthestTier := nextFurthestTier

    int zone_count = array.size(zones)
    if zone_count > 0
        for i = 0 to zone_count - 1
            HtfFvgZone zone = array.get(zones, i)
            if not zone.mitigated
                float dolPrice = bullish ? zone.zoneHigh : zone.zoneLow
                if f_dol_in_bias_direction(bullish, currentPrice, dolPrice)
                    SessionPoiTarget candidate = SessionPoiTarget.new("fvg", zone.formedTime, zone.txt)
                    [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, dolPrice, currentPrice)
                    nearest := nextNearest
                    nearestDistance := nextNearestDistance
                    if f_dol_within_adr(bullish, dolPrice, openPlusAdr, openMinusAdr)
                        [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, dolPrice, currentPrice)
                        furthest := nextFurthest
                        furthestDistance := nextFurthestDistance
                        furthestTier := nextFurthestTier

    int swing_count = array.size(swings)
    if swing_count > 0
        for i = 0 to swing_count - 1
            HtfSwingLevel swing = array.get(swings, i)
            bool bullishSwing = str.contains(swing.txt, "High")
            bool bearishSwing = str.contains(swing.txt, "Low")
            bool directionMatch = bullish ? bullishSwing : bearishSwing
            if not swing.mitigated and directionMatch and f_dol_in_bias_direction(bullish, currentPrice, swing.price)
                SessionPoiTarget candidate = SessionPoiTarget.new("swing", swing.formedTime, swing.txt)
                [nextNearest, nextNearestDistance] = f_update_nearest_dol(nearest, nearestDistance, candidate, swing.price, currentPrice)
                nearest := nextNearest
                nearestDistance := nextNearestDistance
                if f_dol_within_adr(bullish, swing.price, openPlusAdr, openMinusAdr)
                    [nextFurthest, nextFurthestDistance, nextFurthestTier] = f_update_furthest_dol(furthest, furthestDistance, furthestTier, candidate, swing.price, currentPrice)
                    furthest := nextFurthest
                    furthestDistance := nextFurthestDistance
                    furthestTier := nextFurthestTier

    bool useDailyOpenTp1 = reversalDayTp1Enabled and adrConsumptionPct >= 80 and not na(dailyOpen) and f_dol_in_bias_direction(bullish, currentPrice, dailyOpen)
    if useDailyOpenTp1
        nearest := SessionPoiTarget.new("daily-open", na, "Daily Open")

    [nearest, furthest]

f_poi_target_mitigated(SessionPoiTarget poi, array<HtfFvgZone> zones, array<HtfSwingLevel> swings) =>
    bool mitigated = false
    if not na(poi)
        if poi.kind == "fvg"
            bool found = false
            int zone_count = array.size(zones)
            if zone_count > 0
                for i = 0 to zone_count - 1
                    HtfFvgZone zone = array.get(zones, i)
                    if zone.formedTime == poi.formedTime and zone.txt == poi.txt
                        found := true
            mitigated := not found
        else if poi.kind == "swing"
            int swing_count = array.size(swings)
            if swing_count > 0
                for i = 0 to swing_count - 1
                    HtfSwingLevel swing = array.get(swings, i)
                    if swing.formedTime == poi.formedTime and swing.txt == poi.txt
                        mitigated := swing.mitigated
    mitigated

f_range_fully_in(float innerLow, float innerHigh, float outerLow, float outerHigh) =>
    innerLow >= outerLow and innerHigh <= outerHigh

f_middle_fully_overlapped_by_outer(int firstIdx, int middleIdx, int thirdIdx) =>
    float innerLow = low[middleIdx]
    float innerHigh = high[middleIdx]
    float aLow = low[firstIdx]
    float aHigh = high[firstIdx]
    float bLow = low[thirdIdx]
    float bHigh = high[thirdIdx]
    bool inFirst = f_range_fully_in(innerLow, innerHigh, aLow, aHigh)
    bool inThird = f_range_fully_in(innerLow, innerHigh, bLow, bHigh)
    bool spansFirstThenThird = innerLow >= aLow and aHigh >= innerLow and innerHigh <= bHigh and bLow <= aHigh
    bool spansThirdThenFirst = innerLow >= bLow and bHigh >= innerLow and innerHigh <= aHigh and aLow <= bHigh
    inFirst or inThird or spansFirstThenThird or spansThirdThenFirst

f_detect_fvg() =>
    bool bullish = low[0] > high[2]
    bool bearish = high[0] < low[2]
    bool middleOverlapped = f_middle_fully_overlapped_by_outer(2, 1, 0)
    float zoneLow = bullish ? high[2] : bearish ? high[0] : na
    float zoneHigh = bullish ? low[0] : bearish ? low[2] : na
    bool formed = (bullish or bearish) and not middleOverlapped
    [formed, zoneLow, zoneHigh, time, bullish]

f_detect_fvg_with_ohlc() =>
    [formed, zoneLow, zoneHigh, formedTime, bullish] = f_detect_fvg()
    [formed, zoneLow, zoneHigh, formedTime, bullish, low, high, time, close]

f_fvg_closed_through_extreme(bool bullish, float zoneLow, float zoneHigh, float checkClose) =>
    bullish ? checkClose < zoneLow : checkClose > zoneHigh

f_fvg_exists(array<HtfFvgZone> zones, int formedTime, string txt) =>
    bool found = false
    int count = array.size(zones)
    if count > 0
        for i = 0 to count - 1
            HtfFvgZone zone = array.get(zones, i)
            if zone.formedTime == formedTime and zone.txt == txt
                found := true
    found

f_try_add_fvg(
     array<HtfFvgZone> zones,
     bool formed,
     float zoneLow,
     float zoneHigh,
     int formedTime,
     string txt,
     bool bullish
 ) =>
    if formed and not f_fvg_exists(zones, formedTime, txt)
        array.push(zones, HtfFvgZone.new(zoneLow, zoneHigh, formedTime, txt, bullish, false, na))
    zones

f_remove_mitigated_fvgs(array<HtfFvgZone> zones, float checkClose, int checkTime) =>
    int i = array.size(zones) - 1
    while i >= 0
        HtfFvgZone zone = array.get(zones, i)
        if checkTime > zone.formedTime and f_fvg_closed_through_extreme(zone.bullish, zone.zoneLow, zone.zoneHigh, checkClose)
            array.remove(zones, i)
        i -= 1
    zones

f_prune_expired_fvgs(array<HtfFvgZone> zones) =>
    int i = array.size(zones) - 1
    while i >= 0
        HtfFvgZone zone = array.get(zones, i)
        if not f_within_htf_fvg_lookback(zone.formedTime)
            array.remove(zones, i)
        i -= 1
    zones

f_advance_fvg_lifecycle(
     array<HtfFvgZone> zones,
     bool formed,
     float zoneLow,
     float zoneHigh,
     int formedTime,
     string txt,
     bool formedBullish,
     float checkClose,
     int checkTime,
     bool bar_confirmed
 ) =>
    array<HtfFvgZone> result = zones
    if bar_confirmed
        result := f_try_add_fvg(result, formed, zoneLow, zoneHigh, formedTime, txt, formedBullish)
    result := f_remove_mitigated_fvgs(result, checkClose, checkTime)
    result := f_prune_expired_fvgs(result)
    result

f_concat_fvg_arrays(array<HtfFvgZone> left, array<HtfFvgZone> right) =>
    array<HtfFvgZone> combined = array.copy(left)
    int right_count = array.size(right)
    if right_count > 0
        for i = 0 to right_count - 1
            array.push(combined, array.get(right, i))
    combined

// Map a timestamp to the chart bar that contains it (avoids bar_time rounding forward).
// Future targets (e.g. current session close at 17:00 ET) project forward from the active bar.
f_bar_index_for_time(int target_time) =>
    int result = bar_index
    if not na(target_time)
        if target_time > time_close
            int ms_per_bar = timeframe.in_seconds() * 1000
            result := bar_index + int(math.ceil((target_time - time) / ms_per_bar))
        else if target_time >= time
            result := bar_index
        else
            int max_i = math.min(bar_index, BAR_TIME_SEARCH_MAX)
            for i = 0 to max_i
                bool in_bar = time[i] <= target_time and (i == 0 or target_time < time[i - 1])
                if in_bar
                    result := bar_index - i
                    break
            if result == bar_index and time[max_i] > target_time
                result := bar_index - max_i
    result

f_draw_fvg_zones(
     array<box> existing_boxes,
     array<label> existing_labels,
     array<HtfFvgZone> zones,
     int session_end_time,
     SessionPoiTarget session_poi,
     SessionPoiTarget tp1_target,
     SessionPoiTarget tp2_target
 ) =>
    array<box> next_boxes = array.new<box>()
    array<label> next_labels = array.new<label>()
    if barstate.islast
        int box_count = array.size(existing_boxes)
        if box_count > 0
            for i = 0 to box_count - 1
                box.delete(array.get(existing_boxes, i))
        int label_count = array.size(existing_labels)
        if label_count > 0
            for i = 0 to label_count - 1
                label.delete(array.get(existing_labels, i))
        int zone_count = array.size(zones)
        if zone_count > 0
            for i = 0 to zone_count - 1
                HtfFvgZone zone = array.get(zones, i)
                int origin_bi = f_bar_index_for_time(zone.formedTime)
                int end_bi = math.max(origin_bi, f_bar_index_for_time(session_end_time))
                bool is_poi = f_is_session_poi(session_poi, "fvg", zone.formedTime, zone.txt)
                bool is_tp1 = f_is_active_dol(tp1_target, "fvg", zone.formedTime, zone.txt)
                bool is_tp2 = f_is_active_dol(tp2_target, "fvg", zone.formedTime, zone.txt)
                bool is_dol = is_tp1 or is_tp2
                color box_bg = is_poi ? POI_FVG_COLOR : is_dol ? DOL_FVG_COLOR : FVG_COLOR
                color box_border = is_poi ? POI_FVG_BORDER : is_dol ? DOL_FVG_BORDER : color.new(color.teal, 40)
                box next_box = box.new(
                     origin_bi,
                     zone.zoneHigh,
                     end_bi,
                     zone.zoneLow,
                     xloc = xloc.bar_index,
                     bgcolor = box_bg,
                     border_color = box_border,
                     border_width = is_poi or is_dol ? POI_LINE_WIDTH : 1
                 )
                array.push(next_boxes, next_box)
                string label_txt = f_format_level_label(zone.txt, is_poi, is_tp1, is_tp2)
                color label_color = is_poi ? POI_COLOR : is_dol ? DOL_COLOR : color.teal
                label next_label = label.new(
                     end_bi,
                     zone.zoneHigh,
                     label_txt,
                     xloc = xloc.bar_index,
                     style = label.style_label_down,
                     color = color(na),
                     textcolor = label_color,
                     size = LABEL_SIZE
                 )
                array.push(next_labels, next_label)
    [next_boxes, next_labels]

f_draw_level(
     line existing_line,
     label existing_label,
     float price,
     int origin_time,
     int session_end_time,
     string txt,
     bool dashed,
     string label_placement,
     color line_color,
     bool mitigated = false,
     int mitigated_time = na,
     bool is_poi = false,
     bool is_tp1 = false,
     bool is_tp2 = false,
     bool session_context = false,
     bool suppress_label = false
 ) =>
    line next_line = na
    label next_label = na
    if barstate.islast
        if not na(existing_line)
            line.delete(existing_line)
        if not na(existing_label)
            label.delete(existing_label)
        if not na(price) and not na(origin_time) and not na(session_end_time)
            origin_bi = f_bar_index_for_time(origin_time)
            int end_time = mitigated ? mitigated_time : session_end_time
            end_bi = math.max(origin_bi, f_bar_index_for_time(end_time))
            color draw_color = is_poi ? POI_COLOR : (not session_context and (is_tp1 or is_tp2)) ? DOL_COLOR : mitigated ? SWING_MITIGATED_COLOR : line_color
            int line_width = is_poi ? POI_LINE_WIDTH : (not session_context and (is_tp1 or is_tp2)) ? DOL_LINE_WIDTH : 1
            next_line := line.new(
                 origin_bi,
                 price,
                 end_bi,
                 price,
                 xloc = xloc.bar_index,
                 extend = extend.none,
                 color = draw_color,
                 width = line_width,
                 style = dashed ? line.style_dashed : line.style_solid
             )
            if txt != "" and not suppress_label
                string label_txt = f_format_level_label(txt, is_poi, is_tp1, is_tp2)
                next_label := label.new(
                     end_bi,
                     f_label_y(price, label_placement),
                     label_txt,
                     xloc = xloc.bar_index,
                     style = f_label_style(label_placement),
                     color = color(na),
                     textcolor = draw_color,
                     size = LABEL_SIZE
                 )
    [next_line, next_label]

var line pdh_line = na
var line pdl_line = na
var line pwh_line = na
var line pwl_line = na
var line daily_open_line = na
var line open_plus_adr_line = na
var line open_minus_adr_line = na
var line pd_equilibrium_line = na
var label pdh_label = na
var label pdl_label = na
var label pwh_label = na
var label pwl_label = na
var label daily_open_label = na
var label adr_consumption_label = na
var label pd_equilibrium_label = na

var bool pdhMitigated = false
var int pdhMitigatedTime = na
var bool pdlMitigated = false
var int pdlMitigatedTime = na
var SessionPoiTarget sessionPoi = na
var bool directionalFvgPoiAttempted = false
var bool pwhMitigated = false
var int pwhMitigatedTime = na
var bool pwlMitigated = false
var int pwlMitigatedTime = na

open_near_pwl = not na(dailyOpen) and not na(pwl) and math.abs(dailyOpen - pwl) <= syminfo.mintick * LABEL_GAP_TICKS * 4
pdRange = not na(pdh) and not na(pdl) ? pdh - pdl : na
pdEqLow = not na(pdRange) ? pdl + pdRange * 0.25 : na
pdEqHigh = not na(pdRange) ? pdl + pdRange * 0.75 : na
pdEq50 = not na(pdh) and not na(pdl) ? (pdh + pdl) / 2 : na
pd_eq_price = showPdEquilibrium50 ? pdEq50 : na
sessionOpenTime = f_daily_session_open_time()

weekKey = f_cme_week_session_key()
newRailWeek = not na(weekKey) and ta.change(weekKey) != 0

if sessionRolled
    pdhMitigated := false
    pdhMitigatedTime := na
    pdlMitigated := false
    pdlMitigatedTime := na
    sessionPoi := na
    directionalFvgPoiAttempted := false

if newRailWeek
    pwhMitigated := false
    pwhMitigatedTime := na
    pwlMitigated := false
    pwlMitigatedTime := na

if not pdhMitigated and not na(pdh) and not na(dailyOpenTime) and oneMinTime >= dailyOpenTime and oneMinHigh >= pdh
    pdhMitigated := true
    pdhMitigatedTime := oneMinTime

if not pdlMitigated and not na(pdl) and not na(dailyOpenTime) and oneMinTime >= dailyOpenTime and oneMinLow <= pdl
    pdlMitigated := true
    pdlMitigatedTime := oneMinTime

if not pwhMitigated and not na(pwh) and not na(weekKey) and oneMinTime >= weekKey and oneMinHigh >= pwh
    pwhMitigated := true
    pwhMitigatedTime := oneMinTime

if not pwlMitigated and not na(pwl) and not na(weekKey) and oneMinTime >= weekKey and oneMinLow <= pwl
    pwlMitigated := true
    pwlMitigatedTime := oneMinTime

if dailyBias == "Neutral" and na(sessionPoi)
    if pdhMitigated and pdlMitigated
        sessionPoi := pdhMitigatedTime <= pdlMitigatedTime ? SessionPoiTarget.new("pdh", pdhMitigatedTime, "PDH") : SessionPoiTarget.new("pdl", pdlMitigatedTime, "PDL")
    else if pdhMitigated
        sessionPoi := SessionPoiTarget.new("pdh", pdhMitigatedTime, "PDH")
    else if pdlMitigated
        sessionPoi := SessionPoiTarget.new("pdl", pdlMitigatedTime, "PDL")

bool pdhIsPoi = f_is_session_poi(sessionPoi, "pdh", pdhMitigatedTime, "PDH")
bool pdlIsPoi = f_is_session_poi(sessionPoi, "pdl", pdlMitigatedTime, "PDL")

adr_consumption_txt = not na(adrConsumptionPct) ? str.format("ADR {0,number,#.#}%", adrConsumptionPct) : "ADR"
[_open_plus_adr_line, _adr_consumption_label] = f_draw_level(open_plus_adr_line, adr_consumption_label, openPlusAdr, dailyOpenTime, sessionEnd, adr_consumption_txt, true, "above", SESSION_CONTEXT_COLOR)
open_plus_adr_line := _open_plus_adr_line
adr_consumption_label := _adr_consumption_label

[_open_minus_adr_line, _] = f_draw_level(open_minus_adr_line, na, openMinusAdr, dailyOpenTime, sessionEnd, "", true, "below", SESSION_CONTEXT_COLOR)
open_minus_adr_line := _open_minus_adr_line

[_pd_equilibrium_line, _pd_equilibrium_label] = f_draw_level(pd_equilibrium_line, pd_equilibrium_label, pd_eq_price, dailyOpenTime, sessionEnd, "PD EQ 50%", true, "on", SESSION_CONTEXT_COLOR)
pd_equilibrium_line := _pd_equilibrium_line
pd_equilibrium_label := _pd_equilibrium_label

chartTfSeconds = timeframe.in_seconds()
on4hChart = chartTfSeconds == 14400
on1hChart = chartTfSeconds == 3600
showFvgs = on4hChart or on1hChart
fvgLabel = on4hChart ? "4H FVG" : on1hChart ? "1H FVG" : ""

[formed, zoneLow, zoneHigh, formedTime, formedBullish] = f_detect_fvg()

var array<HtfFvgZone> activeFvgs = array.new<HtfFvgZone>()
var array<box> fvg_boxes = array.new<box>()
var array<label> fvg_labels = array.new<label>()
var int lastChartTf = na

if chartTfSeconds != lastChartTf
    array.clear(activeFvgs)
    lastChartTf := chartTfSeconds

if showFvgs
    activeFvgs := f_advance_fvg_lifecycle(activeFvgs, formed, zoneLow, zoneHigh, formedTime, fvgLabel, formedBullish, close, time, barstate.isconfirmed)

fvgZonesToDraw = showFvgs ? activeFvgs : array.new<HtfFvgZone>()

f_strict_fractal_high_confirmed(int pivot) =>
    float pivotHigh = high[pivot]
    pivotHigh > high[pivot + 1] and pivotHigh > high[pivot + 2] and pivotHigh > high[pivot + 3] and pivotHigh > high[pivot - 1] and pivotHigh > high[pivot - 2] and pivotHigh > high[pivot - 3]

f_strict_fractal_low_confirmed(int pivot) =>
    float pivotLow = low[pivot]
    pivotLow < low[pivot + 1] and pivotLow < low[pivot + 2] and pivotLow < low[pivot + 3] and pivotLow < low[pivot - 1] and pivotLow < low[pivot - 2] and pivotLow < low[pivot - 3]

f_htf_swing_signals() =>
    bool highConfirmed = false
    float highPrice = na
    int highPivotTime = na
    int highConfirmedTime = na
    bool lowConfirmed = false
    float lowPrice = na
    int lowPivotTime = na
    int lowConfirmedTime = na
    int pivot = 3
    if barstate.isconfirmed
        if f_strict_fractal_high_confirmed(pivot)
            highConfirmed := true
            highPrice := high[pivot]
            highPivotTime := time[pivot]
            highConfirmedTime := time
        if f_strict_fractal_low_confirmed(pivot)
            lowConfirmed := true
            lowPrice := low[pivot]
            lowPivotTime := time[pivot]
            lowConfirmedTime := time
    [highConfirmed, highPrice, highPivotTime, highConfirmedTime, lowConfirmed, lowPrice, lowPivotTime, lowConfirmedTime]

f_swing_visible(float price, int formedTime, float pwh, float pwl, float curWeekHigh, float curWeekLow) =>
    if not f_within_htf_swing_lookback(formedTime)
        false
    else
        float rangeLow = math.min(pwl, curWeekLow)
        float rangeHigh = math.max(pwh, curWeekHigh)
        price >= rangeLow and price <= rangeHigh

f_swing_exists(array<HtfSwingLevel> swings, int formedTime, string txt) =>
    bool found = false
    int count = array.size(swings)
    if count > 0
        for i = 0 to count - 1
            HtfSwingLevel swing = array.get(swings, i)
            if swing.formedTime == formedTime and swing.txt == txt
                found := true
    found

f_try_add_swing(
     array<HtfSwingLevel> swings,
     bool confirmed,
     float price,
     int formedTime,
     int confirmedTime,
     string txt,
     float pwh,
     float pwl,
     float curWeekHigh,
     float curWeekLow
 ) =>
    if confirmed and not na(price) and not na(formedTime) and not na(confirmedTime) and f_swing_visible(price, formedTime, pwh, pwl, curWeekHigh, curWeekLow) and not f_swing_exists(swings, formedTime, txt)
        array.push(swings, HtfSwingLevel.new(price, formedTime, confirmedTime, txt, false, na))
    swings

f_swing_swept(HtfSwingLevel swing, float checkLow, float checkHigh) =>
    bool isHigh = str.contains(swing.txt, "High")
    bool isLow = str.contains(swing.txt, "Low")
    (isHigh and checkHigh >= swing.price) or (isLow and checkLow <= swing.price)

f_sweep_swings(array<HtfSwingLevel> swings, float checkLow, float checkHigh, int checkTime) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if not swing.mitigated and checkTime > swing.confirmedTime and f_swing_swept(swing, checkLow, checkHigh)
            array.set(swings, i, HtfSwingLevel.new(swing.price, swing.formedTime, swing.confirmedTime, swing.txt, true, checkTime))
        i -= 1
    swings

f_remove_all_mitigated_swings(array<HtfSwingLevel> swings) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if swing.mitigated
            array.remove(swings, i)
        i -= 1
    swings

f_prune_stale_mitigated_swings(array<HtfSwingLevel> swings) =>
    int currentSession = f_cme_daily_session_key()
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if swing.mitigated
            int mitigatedSession = f_cme_daily_session_key_for(swing.mitigatedTime)
            if na(mitigatedSession) or mitigatedSession != currentSession
                array.remove(swings, i)
        i -= 1
    swings

f_prune_invisible_swings(array<HtfSwingLevel> swings, float pwh, float pwl, float curWeekHigh, float curWeekLow) =>
    int i = array.size(swings) - 1
    while i >= 0
        HtfSwingLevel swing = array.get(swings, i)
        if not f_swing_visible(swing.price, swing.formedTime, pwh, pwl, curWeekHigh, curWeekLow)
            array.remove(swings, i)
        i -= 1
    swings

f_draw_swing_levels(
     array<line> existing_lines,
     array<label> existing_labels,
     array<HtfSwingLevel> swings,
     int session_end_time,
     SessionPoiTarget session_poi,
     SessionPoiTarget tp1_target,
     SessionPoiTarget tp2_target,
     float pdh,
     float pdl,
     bool pdhMitigated,
     bool pdlMitigated,
     float pwh,
     float pwl,
     bool pwhMitigated,
     bool pwlMitigated
 ) =>
    array<line> next_lines = array.new<line>()
    array<label> next_labels = array.new<label>()
    if barstate.islast
        int line_count = array.size(existing_lines)
        if line_count > 0
            for i = 0 to line_count - 1
                line.delete(array.get(existing_lines, i))
        int label_count = array.size(existing_labels)
        if label_count > 0
            for i = 0 to label_count - 1
                label.delete(array.get(existing_labels, i))
        int swing_count = array.size(swings)
        if swing_count > 0
            for drawRank = 1 to 2
                for i = 0 to swing_count - 1
                    HtfSwingLevel swing = array.get(swings, i)
                    if f_timeframe_rank(swing.txt) != drawRank
                        continue
                    int origin_bi = f_bar_index_for_time(swing.formedTime)
                    int end_time = swing.mitigated ? swing.mitigatedTime : session_end_time
                    int end_bi = math.max(origin_bi, f_bar_index_for_time(end_time))
                    bool is_poi = f_is_session_poi(session_poi, "swing", swing.formedTime, swing.txt)
                    bool is_tp1 = f_is_active_dol(tp1_target, "swing", swing.formedTime, swing.txt)
                    bool is_tp2 = f_is_active_dol(tp2_target, "swing", swing.formedTime, swing.txt)
                    bool is_dol = is_tp1 or is_tp2
                    color line_color = swing.mitigated ? SWING_MITIGATED_COLOR : is_poi ? POI_COLOR : is_dol ? DOL_COLOR : LEVEL_COLOR
                    int line_width = is_poi or is_dol ? POI_LINE_WIDTH : 1
                    line next_line = line.new(
                         origin_bi,
                         swing.price,
                         end_bi,
                         swing.price,
                         xloc = xloc.bar_index,
                         extend = extend.none,
                         color = line_color,
                         width = line_width,
                         style = line.style_solid
                     )
                    array.push(next_lines, next_line)
                    if not swing.mitigated and not f_swing_label_suppressed_by_higher_tf(swings, swing) and not f_swing_label_suppressed_by_liquidity_rail(swing, pdh, pdl, pdhMitigated, pdlMitigated, pwh, pwl, pwhMitigated, pwlMitigated)
                        string label_txt = f_format_level_label(swing.txt, is_poi, is_tp1, is_tp2)
                        label next_label = label.new(
                             end_bi,
                             f_label_y(swing.price, "on"),
                             label_txt,
                             xloc = xloc.bar_index,
                             style = label.style_label_left,
                             color = color(na),
                             textcolor = line_color,
                             size = LABEL_SIZE
                         )
                        array.push(next_labels, next_label)
    [next_lines, next_labels]

[
     highConfirmed4h,
     highPrice4h,
     highPivotTime4h,
     highConfirmedTime4h,
     lowConfirmed4h,
     lowPrice4h,
     lowPivotTime4h,
     lowConfirmedTime4h
 ] = request.security(
     syminfo.tickerid,
     "240",
     f_htf_swing_signals(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[
     highConfirmed1h,
     highPrice1h,
     highPivotTime1h,
     highConfirmedTime1h,
     lowConfirmed1h,
     lowPrice1h,
     lowPivotTime1h,
     lowConfirmedTime1h
 ] = request.security(
     syminfo.tickerid,
     "60",
     f_htf_swing_signals(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[formed4h, zoneLow4h, zoneHigh4h, formedTime4h, bullish4h, _, _, mitigateTime4h, mitigateClose4h] = request.security(
     syminfo.tickerid,
     "240",
     f_detect_fvg_with_ohlc(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

[formed1h, zoneLow1h, zoneHigh1h, formedTime1h, bullish1h, _, _, mitigateTime1h, mitigateClose1h] = request.security(
     syminfo.tickerid,
     "60",
     f_detect_fvg_with_ohlc(),
     gaps = barmerge.gaps_off,
     lookahead = barmerge.lookahead_off
 )

var array<HtfFvgZone> poiFvgs4h = array.new<HtfFvgZone>()
var array<HtfFvgZone> poiFvgs1h = array.new<HtfFvgZone>()

var array<HtfSwingLevel> activeSwings = array.new<HtfSwingLevel>()
var array<line> swing_lines = array.new<line>()
var array<label> swing_labels = array.new<label>()

if newRailWeek
    activeSwings := f_prune_invisible_swings(activeSwings, pwh, pwl, currentWeekHigh, currentWeekLow)

if sessionRolled
    activeSwings := f_remove_all_mitigated_swings(activeSwings)

activeSwings := f_try_add_swing(activeSwings, highConfirmed4h, highPrice4h, highPivotTime4h, highConfirmedTime4h, "4H Swing High", pwh, pwl, currentWeekHigh, currentWeekLow)
activeSwings := f_try_add_swing(activeSwings, lowConfirmed4h, lowPrice4h, lowPivotTime4h, lowConfirmedTime4h, "4H Swing Low", pwh, pwl, currentWeekHigh, currentWeekLow)
activeSwings := f_try_add_swing(activeSwings, highConfirmed1h, highPrice1h, highPivotTime1h, highConfirmedTime1h, "1H Swing High", pwh, pwl, currentWeekHigh, currentWeekLow)
activeSwings := f_try_add_swing(activeSwings, lowConfirmed1h, lowPrice1h, lowPivotTime1h, lowConfirmedTime1h, "1H Swing Low", pwh, pwl, currentWeekHigh, currentWeekLow)
activeSwings := f_sweep_swings(activeSwings, oneMinLow, oneMinHigh, oneMinTime)
activeSwings := f_prune_stale_mitigated_swings(activeSwings)
activeSwings := f_prune_invisible_swings(activeSwings, pwh, pwl, currentWeekHigh, currentWeekLow)

poiFvgs4h := f_advance_fvg_lifecycle(poiFvgs4h, formed4h, zoneLow4h, zoneHigh4h, formedTime4h, "4H FVG", bullish4h, mitigateClose4h, mitigateTime4h, barstate.isconfirmed)
poiFvgs1h := f_advance_fvg_lifecycle(poiFvgs1h, formed1h, zoneLow1h, zoneHigh1h, formedTime1h, "1H FVG", bullish1h, mitigateClose1h, mitigateTime1h, barstate.isconfirmed)
allPoiFvgs = f_concat_fvg_arrays(poiFvgs4h, poiFvgs1h)

if dailyBias == "Directional" and not directionalFvgPoiAttempted and time >= sessionOpenTime and not na(pdEqLow) and not na(pdEqHigh)
    sessionPoi := f_select_directional_fvg_poi(allPoiFvgs, pdEqLow, pdEqHigh, sessionOpenTime, close)
    directionalFvgPoiAttempted := true

if dailyBias == "Directional" and directionalFvgPoiAttempted and na(sessionPoi)
    sessionPoi := f_select_defer_swing_poi(activeSwings, sessionOpenTime, close, time)

if not na(sessionPoi) and f_poi_target_mitigated(sessionPoi, allPoiFvgs, activeSwings)
    sessionPoi := na

bool bullishBias = biasDirection == "Bullish"
[activeDolTp1, activeDolTp2] = f_resolve_active_dol(bullishBias, close, dailyOpen, adrConsumptionPct, reversalDayTp1, openPlusAdr, openMinusAdr, pdh, pdl, pwh, pwl, pdhMitigated, pdlMitigated, pwhMitigated, pwlMitigated, allPoiFvgs, activeSwings)

bool dailyOpenIsTp1 = f_is_active_dol(activeDolTp1, "daily-open", na, "Daily Open")
[_daily_open_line, _daily_open_label] = f_draw_level(daily_open_line, daily_open_label, dailyOpen, dailyOpenTime, sessionEnd, "Daily Open", true, "above", SESSION_CONTEXT_COLOR, false, na, false, dailyOpenIsTp1, false, true)
daily_open_line := _daily_open_line
daily_open_label := _daily_open_label

bool pdhIsTp1 = f_is_active_dol(activeDolTp1, "pdh", pdhMitigatedTime, "PDH")
bool pdhIsTp2 = f_is_active_dol(activeDolTp2, "pdh", pdhMitigatedTime, "PDH")
bool pdhLabelSuppressed = f_daily_rail_label_suppressed("pdh", pdh, pwh, pwl, pwhMitigated, pwlMitigated)
[_pdh_line, _pdh_label] = f_draw_level(pdh_line, pdh_label, pdh, pdhTime, sessionEnd, "PDH", false, "on", LEVEL_COLOR, pdhMitigated, pdhMitigatedTime, pdhIsPoi, pdhIsTp1, pdhIsTp2, false, pdhLabelSuppressed)
pdh_line := _pdh_line
pdh_label := _pdh_label

bool pdlIsTp1 = f_is_active_dol(activeDolTp1, "pdl", pdlMitigatedTime, "PDL")
bool pdlIsTp2 = f_is_active_dol(activeDolTp2, "pdl", pdlMitigatedTime, "PDL")
bool pdlLabelSuppressed = f_daily_rail_label_suppressed("pdl", pdl, pwh, pwl, pwhMitigated, pwlMitigated)
[_pdl_line, _pdl_label] = f_draw_level(pdl_line, pdl_label, pdl, pdlTime, sessionEnd, "PDL", false, "on", LEVEL_COLOR, pdlMitigated, pdlMitigatedTime, pdlIsPoi, pdlIsTp1, pdlIsTp2, false, pdlLabelSuppressed)
pdl_line := _pdl_line
pdl_label := _pdl_label

bool pwhIsTp1 = f_is_active_dol(activeDolTp1, "pwh", pwhMitigatedTime, "PWH")
bool pwhIsTp2 = f_is_active_dol(activeDolTp2, "pwh", pwhMitigatedTime, "PWH")
[_pwh_line, _pwh_label] = f_draw_level(pwh_line, pwh_label, pwh, pwhTime, sessionEnd, "PWH", false, "on", LEVEL_COLOR, pwhMitigated, pwhMitigatedTime, false, pwhIsTp1, pwhIsTp2)
pwh_line := _pwh_line
pwh_label := _pwh_label

bool pwlIsTp1 = f_is_active_dol(activeDolTp1, "pwl", pwlMitigatedTime, "PWL")
bool pwlIsTp2 = f_is_active_dol(activeDolTp2, "pwl", pwlMitigatedTime, "PWL")
[_pwl_line, _pwl_label] = f_draw_level(pwl_line, pwl_label, pwl, pwlTime, sessionEnd, "PWL", false, open_near_pwl ? "below" : "on", LEVEL_COLOR, pwlMitigated, pwlMitigatedTime, false, pwlIsTp1, pwlIsTp2)
pwl_line := _pwl_line
pwl_label := _pwl_label

[_fvg_boxes, _fvg_labels] = f_draw_fvg_zones(fvg_boxes, fvg_labels, fvgZonesToDraw, sessionEnd, sessionPoi, activeDolTp1, activeDolTp2)
fvg_boxes := _fvg_boxes
fvg_labels := _fvg_labels

[_swing_lines, _swing_labels] = f_draw_swing_levels(swing_lines, swing_labels, activeSwings, sessionEnd, sessionPoi, activeDolTp1, activeDolTp2, pdh, pdl, pdhMitigated, pdlMitigated, pwh, pwl, pwhMitigated, pwlMitigated)
swing_lines := _swing_lines
swing_labels := _swing_labels
